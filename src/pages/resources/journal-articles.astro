---
import Layout from '../../components/layout/Layout.astro';
---

<Layout
  title="Journal Articles — Resources — Ophthalytics"
  description="Peer-reviewed research advancing the science of AI-assisted retinal diagnostics."
>
  <!-- SECTION 1 — HERO -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-16 md:py-20">
      <nav aria-label="Breadcrumb" class="text-sm text-brand-muted">
        <a href="/resources" class="hover:text-brand-primary">Resources</a>
        <span class="mx-2">/</span>
        <span class="text-brand-ink">Journal Articles</span>
      </nav>
      <h1 class="mt-4 text-4xl md:text-5xl font-bold text-brand-ink leading-tight">
        Journal Articles
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-brand-body leading-relaxed">
        Peer-reviewed research advancing the science of AI-assisted retinal diagnostics.
      </p>
    </div>
  </section>

  <!-- SECTION 2 — ARTICLES LIST -->
  <section class="bg-white">
    <div class="max-w-5xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <article class="grid gap-8 md:grid-cols-[240px_1fr] items-start bg-white rounded-2xl border border-brand-line p-6 md:p-8">
        <div class="rounded-lg overflow-hidden shadow-md">
          <img
            src="/resources/journal-cover.png"
            alt="Diagnostics journal cover"
            class="w-full h-auto aspect-[3/4] object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <span class="inline-block rounded-full bg-brand-primary/10 text-brand-primary text-xs uppercase tracking-widest font-semibold px-3 py-1">
            Peer-Reviewed Research
          </span>
          <p class="mt-3 text-sm text-brand-muted">
            Diagnostics (MDPI) · Volume 13, Issue 3 · 2023
          </p>
          <h2 class="mt-2 text-2xl font-bold text-brand-ink leading-snug">
            A Prospective Study on Diabetic Retinopathy Detection Based on a Modified Convolutional Neural Network Using Fundus Images at Sindh Institute of Ophthalmology &amp; Visual Sciences
          </h2>
          <p class="mt-4 text-base text-brand-body leading-relaxed">
            This study presents a prospective evaluation of a modified convolutional neural network for diabetic retinopathy detection using fundus images collected at the Sindh Institute of Ophthalmology &amp; Visual Sciences. The model was evaluated for sensitivity, specificity, and clinical applicability in real-world screening conditions.
          </p>
          <p class="mt-4 text-sm text-brand-muted">
            Authored by Ophthalytics co-founders and clinical partners
          </p>
          <a
            href="https://www.mdpi.com/2075-4418/13/3/393"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-brand-primary font-semibold hover:gap-3 transition-all"
          >
            Read on MDPI
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <polyline points="15 3 21 3 21 9"/>
              <line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
          </a>
        </div>
      </article>

      <div class="mt-12 p-8 rounded-2xl bg-brand-surface border border-brand-line text-center">
        <p class="text-brand-body">
          More peer-reviewed research is coming soon. Visit again or
          <button
            type="button"
            data-open-modal="contact"
            class="text-brand-primary font-semibold hover:underline"
          >get updates</button>
          to be notified.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — RELATED RESOURCES -->
  <section class="bg-brand-surface">
    <div class="max-w-5xl mx-auto px-6 md:px-8 lg:px-12 py-16">
      <h2 class="text-xl font-semibold text-brand-ink text-center">Related Resources</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <a href="/resources/newsroom" class="group bg-white border border-brand-line rounded-xl p-6 hover:shadow-lg transition-all">
          <p class="text-xs uppercase tracking-widest text-brand-primary font-semibold">Resources</p>
          <h3 class="mt-2 text-lg font-bold text-brand-ink">Newsroom →</h3>
          <p class="mt-2 text-sm text-brand-body">Press releases, company news, and conference appearances.</p>
        </a>
        <a href="/resources/innovation-pipeline" class="group bg-white border border-brand-line rounded-xl p-6 hover:shadow-lg transition-all">
          <p class="text-xs uppercase tracking-widest text-brand-primary font-semibold">Resources</p>
          <h3 class="mt-2 text-lg font-bold text-brand-ink">Innovation Pipeline →</h3>
          <p class="mt-2 text-sm text-brand-body">What we're building next beyond the current product lineup.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
