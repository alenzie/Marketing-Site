---
import Layout from '../../components/layout/Layout.astro';
import PipeHeading from '../../components/content/PipeHeading.astro';

const categories = [
  {
    href: '/resources/articles',
    title: 'Articles',
    body: 'Industry insights from the Ophthalytics team on early detection, AI-assisted screening, and the future of preventive eye care.',
    cta: 'Read articles',
    image: '/images/resources/articles.webp',
  },
  {
    href: '/resources/journal-articles',
    title: 'Journal Articles',
    body: 'Peer-reviewed research authored by the Ophthalytics team, exploring the clinical and technical foundations of our AI platforms.',
    cta: 'Browse journal articles',
    image: '/images/resources/journal.webp',
  },
  {
    href: '/resources/newsroom',
    title: 'Newsroom',
    body: 'Press releases, company news, conference appearances, and announcements from the Ophthalytics team.',
    cta: 'Read the latest',
    image: '/images/resources/newsroom.webp',
  },
  {
    href: '/resources/innovation-pipeline',
    title: 'Innovation Pipeline',
    body: 'The next generation of AI-powered diagnostics—4Front360, cardiovascular risk assessment, and the "Windows to 270 Diseases" initiative.',
    cta: "Explore what's next",
    image: '/images/resources/innovation.webp',
  },
];
---

<Layout
  title="Resources — Ophthalytics"
  description="Ophthalytics resources, news, testimonies, and more."
>
  <!-- SECTION 1 — HERO -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-28">
      <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">Resources</p>
      <h1 class="mt-3 text-5xl md:text-6xl font-bold text-brand-ink leading-tight">
        Resources
      </h1>
      <p class="mt-6 max-w-2xl text-lg md:text-xl text-brand-body leading-relaxed" data-reveal>
        Ophthalytics resources, news, testimonies, and more.
      </p>
    </div>
  </section>

  <!-- SECTION 2 — CATEGORY CARDS -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-reveal-group>
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="group bg-white border border-brand-line rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all flex flex-col"
          >
            <img
              src={cat.image}
              alt=""
              width="96"
              height="96"
              class="w-12 h-12 object-contain mb-5"
              loading="lazy"
              decoding="async"
            />

            <h2 class="text-2xl font-bold text-brand-ink mb-3">{cat.title}</h2>
            <p class="text-base text-brand-body leading-relaxed flex-1">{cat.body}</p>
            <span class="mt-6 inline-flex items-center gap-1 text-brand-primary font-semibold">
              {cat.cta}
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 3 — FEATURED RESEARCH -->
  <section class="bg-brand-surface">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <PipeHeading level="h2" size="text-sm uppercase tracking-widest" color="text-brand-primary" data-reveal>
        FEATURED RESEARCH
      </PipeHeading>
      <div class="mt-8 grid gap-8 md:grid-cols-5 items-center bg-white rounded-2xl border border-brand-line overflow-hidden" data-reveal>
        <div class="md:col-span-2">
          <img
            src="/resources/journal-cover.png"
            alt="Journal article cover"
            class="w-full h-full object-cover aspect-[3/4] md:aspect-auto"
            loading="lazy"
          />
        </div>
        <div class="md:col-span-3 p-6 md:p-10">
          <span class="inline-block rounded-full bg-brand-primary/10 text-brand-primary text-xs uppercase tracking-widest font-semibold px-3 py-1">
            Journal Article
          </span>
          <h3 class="mt-4 text-2xl md:text-3xl font-bold text-brand-ink leading-snug">
            A Prospective Study on Diabetic Retinopathy Detection Based on a Modified Convolutional Neural Network Using Fundus Images at Sindh Institute of Ophthalmology &amp; Visual Sciences
          </h3>
          <p class="mt-3 text-sm text-brand-muted">
            Authored by Ophthalytics co-founders and clinical partners
          </p>
          <p class="mt-4 text-base text-brand-body leading-relaxed">
            Published peer-reviewed research documenting the performance of our early deep-learning models on diabetic retinopathy detection using standard fundus imaging.
          </p>
          <a
            href="https://www.mdpi.com/2075-4418/13/3/393"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-brand-primary font-semibold hover:gap-3 transition-all"
          >
            Read the Article
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
