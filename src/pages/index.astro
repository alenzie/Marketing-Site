---
import Layout from '../components/layout/Layout.astro';
import Hero from '../components/content/Hero.astro';
import PipeHeading from '../components/content/PipeHeading.astro';
import CapabilityTile from '../components/content/CapabilityTile.astro';
import AudienceCard from '../components/content/AudienceCard.astro';
import TestimonialFeature from '../components/content/TestimonialFeature.astro';
import ResourceCard from '../components/content/ResourceCard.astro';
import CanvasHero from '../components/canvas/CanvasHero.astro';
import RetinalIntelligenceCanvas from '../components/canvas/RetinalIntelligenceCanvas.astro';
---

<Layout
  title="Ophthalytics — Wellness Through the Eyes™"
  description="AI-Powered Retinal Intelligence for earlier detection and better health."
  currentPath="/"
>

  <!-- SECTION 1 — HERO -->
  <Hero
    eyebrow="Ophthalytics — Wellness Through the Eyes™"
    headline="Retinal Intelligence for Earlier Detection and Better Health"
    subheadline="Advancing eye care through AI, oculomics, and multimodal intelligence—transforming the retina into a gateway for early disease detection and broader health insights."
    primaryCta={{ label: 'Request a Demo', openModal: 'demo' }}
    secondaryCta={{ label: 'Explore Our Solutions', href: '/solutions' }}
  >
    <div slot="visual">
      <CanvasHero
        staticFallbackSrc="/images/hero/retinal-intelligence-static.jpg"
        staticFallbackAlt="Visualization of Ophthalytics retinal AI analyzing imaging and detecting signals across brain, heart, metabolic, and respiratory systems"
        aspectClass="aspect-[4/3]"
        ariaLabel="Live retinal AI visualization: a central eye with orbiting data particles linking to brain, heart, metabolic, and respiratory icons."
      >
        <RetinalIntelligenceCanvas />
      </CanvasHero>
    </div>
  </Hero>

  <!-- SECTION 1.5 — EYE-SCAN BANNER (transition under hero) -->
  <section class="relative overflow-hidden">
    <div class="relative h-44 md:h-56 lg:h-64">
      <img
        src="/images/sections/eye-scan-banner.jpg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <!-- Top + bottom gradient blend so the banner fades into white above and below -->
      <div class="absolute inset-0 bg-gradient-to-b from-white via-transparent to-white pointer-events-none"></div>
      <div class="absolute inset-0 bg-brand-primary/10 pointer-events-none"></div>
    </div>
  </section>

  <!-- SECTION 2 — VISION ("Beyond the Eye") -->
  <section class="relative bg-white overflow-hidden">
    <!-- Right-side hero photo, gradient-faded into the left -->
    <div class="absolute inset-y-0 right-0 w-full md:w-3/5 lg:w-1/2" aria-hidden="true">
      <img
        src="/images/sections/dr-ai-computer-screen.jpg"
        alt=""
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <!-- Gradient veil: solid white on the left, transparent on the right -->
      <div class="absolute inset-0 bg-gradient-to-r from-white via-white/85 to-white/0 md:from-white md:via-white/60 md:to-transparent"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-28 grid md:grid-cols-2 items-center">
      <div class="bg-white/70 backdrop-blur-sm rounded-2xl p-8 md:p-10 shadow-sm ring-1 ring-brand-line/60">
        <PipeHeading level="h2" data-reveal>Beyond the Eye: A New Frontier in Detection</PipeHeading>
        <div class="mt-6 space-y-5 text-lg text-brand-body leading-relaxed" data-reveal>
          <p>The retina is one of the only places in the body where microvascular and neural structures can be observed directly and noninvasively.</p>
          <p>At Ophthalytics, we are advancing the field of oculomics—where retinal imaging extends beyond eye disease to reveal early indicators of systemic health.</p>
          <p>By combining AI with multimodal data, we enable earlier risk detection, deeper clinical insights, and more connected care.</p>
          <p>This is the future of preventive healthcare—starting with the eye.</p>
        </div>
      </div>
      <!-- Empty spacer column so the photo on the right has visual breathing room -->
      <div class="hidden md:block"></div>
    </div>
  </section>

  <!-- SECTION 3 — FLAGSHIP (Ocula360 + Core Strengths) -->
  <section class="bg-brand-surface">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">

      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
        <div>
          <p class="text-xs uppercase tracking-widest text-brand-muted font-semibold">
            Ophthalytics Inc — Product Portfolio
          </p>
          <p class="mt-1 text-sm text-brand-body">AI-Powered Retinal Intelligence</p>
        </div>
        <span class="self-start md:self-auto inline-block rounded-full bg-brand-primary text-white px-4 py-1.5 text-sm font-medium">
          Wellness Through the Eyes™
        </span>
      </div>

      <div class="grid gap-6 md:grid-cols-2" data-reveal-group>
        <!-- Flagship Card -->
        <div class="bg-white border border-brand-line rounded-2xl p-8 md:p-10 shadow-md">
          <p class="text-xs uppercase tracking-widest text-brand-primary-light font-semibold">
            Flagship Innovation
          </p>
          <h2 class="mt-3 text-4xl font-bold text-brand-ink">Ocula360</h2>
          <p class="mt-4 text-3xl font-bold text-brand-primary leading-tight">
            Foundational Retinal AI
          </p>
          <p class="mt-5 text-base text-brand-body leading-relaxed">
            Ocula360 is our flagship AI engine designed to detect multiple retinal diseases from a single image. Built on a foundational model architecture, it enables scalable screening, advanced DRSS scoring, and future-ready multimodal applications.
          </p>
          <p class="mt-4 text-base text-brand-body leading-relaxed">
            From clinical workflows to research environments, Ocula360 transforms retinal imaging into actionable diagnostic intelligence.
          </p>
          <a
            href="/solutions/ocula360"
            class="mt-6 inline-flex items-center gap-2 text-brand-primary font-semibold hover:gap-3 transition-all"
          >
            Learn more about Ocula360
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>

        <!-- Core Strengths Card -->
        <div class="relative rounded-2xl p-8 md:p-10 overflow-hidden bg-gradient-to-br from-[#0F2C5C] via-[#123F6E] to-[#0F6F7D] text-white">
          <p class="text-xs uppercase tracking-widest text-brand-secondary font-semibold">
            Core Strengths
          </p>
          <p class="mt-3 text-3xl font-bold leading-tight">
            From one retinal image to scalable diagnostic intelligence.
          </p>
          <p class="mt-5 text-base text-white/80 leading-relaxed">
            Multi-disease detection, explainable AI outputs, DR severity support, and flexible deployment models for providers, payers, eye care, and global screening markets.
          </p>
        </div>
      </div>

      <div class="mt-6 grid gap-5 md:grid-cols-3" data-reveal-group>
        <CapabilityTile
          title="Multi-Disease Detection"
          body="Detects diabetic retinopathy, AMD, glaucoma indicators, and vascular abnormalities."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/>
            <path d="M14.5 2a2.5 2.5 0 0 0-2.5 2.5v15a2.5 2.5 0 0 0 4.96.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/>
          </svg>
        </CapabilityTile>
        <CapabilityTile
          title="DRSS Scoring"
          body="Automated severity grading to support disease staging and screening workflows."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 3v18h18"/>
            <path d="M7 16V9"/>
            <path d="M12 16v-5"/>
            <path d="M17 16v-3"/>
          </svg>
        </CapabilityTile>
        <CapabilityTile
          title="Explainable & Multimodal"
          body="Lesion-level visualization, confidence outputs, and compatibility with imaging and patient context."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 2 7 12 12 22 7 12 2"/>
            <polyline points="2 17 12 22 22 17"/>
            <polyline points="2 12 12 17 22 12"/>
          </svg>
        </CapabilityTile>
      </div>
    </div>
  </section>

  <!-- SECTION 4 — PRODUCT ECOSYSTEM (2x2 grid w/ product imagery) -->
  <section id="products" class="bg-white scroll-mt-24">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <div class="text-center max-w-3xl mx-auto mb-14" data-reveal>
        <PipeHeading level="h2">One Company. Four Retinal AI Solutions.</PipeHeading>
        <p class="mt-4 text-lg text-brand-body leading-relaxed">
          Purpose-built solutions for every point of care.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2" data-reveal-group>
        <!-- Ocula360 (flagship) -->
        <article class="group bg-white border border-brand-line rounded-2xl shadow-sm overflow-hidden flex flex-col hover:shadow-lg transition-shadow">
          <div class="relative aspect-[16/10] bg-brand-surface-blue overflow-hidden">
            <img
              src="/images/products/ocula360-product.png"
              alt="Ocula360 retinal AI dashboard"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
            <span class="absolute top-3 left-3 inline-block rounded-full bg-brand-primary text-white text-[10px] font-semibold uppercase tracking-widest px-2.5 py-1 shadow">
              Flagship
            </span>
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-2xl font-bold text-brand-ink">Ocula360</h3>
            <p class="mt-2 text-sm font-semibold text-brand-primary">
              Foundational Retinal AI Engine
            </p>
            <p class="mt-3 text-sm text-brand-body leading-relaxed">
              The platform behind every Ophthalytics solution. Built on a foundational model architecture, Ocula360 detects multiple retinal diseases from a single image and powers DRSS scoring, explainable outputs, and future-ready multimodal applications.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-brand-body">
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Multi-disease detection</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>DRSS severity grading</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Explainable &amp; multimodal outputs</span></li>
            </ul>
            <a
              href="/solutions/ocula360"
              class="mt-auto pt-5 inline-flex items-center gap-2 text-brand-primary font-semibold group-hover:gap-3 transition-all"
            >
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </article>

        <!-- Nsight360 -->
        <article class="group bg-white border border-brand-line rounded-2xl shadow-sm overflow-hidden flex flex-col hover:shadow-lg transition-shadow">
          <div class="relative aspect-[16/10] bg-brand-surface-blue overflow-hidden">
            <img
              src="/images/products/nsight360-product.png"
              alt="Nsight360 AI-assisted retinal screening on a laptop"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-2xl font-bold text-brand-ink">Nsight360</h3>
            <p class="mt-2 text-sm font-semibold text-brand-primary">
              AI-Assisted Retinal Screening for Primary Care
            </p>
            <p class="mt-3 text-sm text-brand-body leading-relaxed">
              Brings retinal screening directly into primary care settings, enabling non-specialists to capture retinal images and receive AI-assisted reports with expert review—closing care gaps and identifying at-risk patients before vision loss occurs.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-brand-body">
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Primary care integration</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Human + AI workflow</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Scalable screening programs</span></li>
            </ul>
            <a
              href="/solutions/nsight360"
              class="mt-auto pt-5 inline-flex items-center gap-2 text-brand-primary font-semibold group-hover:gap-3 transition-all"
            >
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </article>

        <!-- 2nd Opinion -->
        <article class="group bg-white border border-brand-line rounded-2xl shadow-sm overflow-hidden flex flex-col hover:shadow-lg transition-shadow">
          <div class="relative aspect-[16/10] bg-brand-surface-blue overflow-hidden">
            <img
              src="/images/products/2nd-opinion-product.png"
              alt="2nd Opinion AI diagnostic comparison view"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-2xl font-bold text-brand-ink">2nd Opinion</h3>
            <p class="mt-2 text-sm font-semibold text-brand-primary">
              AI-Enhanced Diagnostic Support for Optometry
            </p>
            <p class="mt-3 text-sm text-brand-body leading-relaxed">
              Built for optometrists and eye care professionals seeking greater confidence in retinal assessments. Provides AI-supported analysis that highlights subtle findings and reduces diagnostic uncertainty without disrupting existing practice workflows.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-brand-body">
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Lesion-level visualization</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Decision support</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Workflow integration</span></li>
            </ul>
            <a
              href="/solutions/2nd-opinion"
              class="mt-auto pt-5 inline-flex items-center gap-2 text-brand-primary font-semibold group-hover:gap-3 transition-all"
            >
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </article>

        <!-- Ophthal360 -->
        <article class="group bg-white border border-brand-line rounded-2xl shadow-sm overflow-hidden flex flex-col hover:shadow-lg transition-shadow">
          <div class="relative aspect-[16/10] bg-brand-surface-blue overflow-hidden">
            <img
              src="/images/products/ophthal360-product.jpg"
              alt="Ophthal360 autonomous retinal AI in clinical use"
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="p-7 flex flex-col flex-1">
            <h3 class="text-2xl font-bold text-brand-ink">Ophthal360</h3>
            <p class="mt-2 text-sm font-semibold text-brand-primary">
              Autonomous AI for Scalable Retinal Screening
            </p>
            <p class="mt-3 text-sm text-brand-body leading-relaxed">
              Designed for high-volume retinal screening across healthcare systems and large-scale programs. Standardizes screening processes and supports timely referral decisions with minimal manual intervention—built for reach in underserved and resource-limited settings.
            </p>
            <ul class="mt-4 space-y-1.5 text-sm text-brand-body">
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Autonomous detection</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>High-throughput screening</span></li>
              <li class="flex gap-2"><span class="text-brand-primary mt-0.5">•</span><span>Automated referral logic</span></li>
            </ul>
            <a
              href="/solutions/ophthal360"
              class="mt-auto pt-5 inline-flex items-center gap-2 text-brand-primary font-semibold group-hover:gap-3 transition-all"
            >
              Learn more
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        </article>
      </div>

      <div class="mt-12 flex flex-col md:flex-row md:items-center md:justify-between gap-2 text-xs text-brand-muted">
        <span>Atlanta, Georgia, USA</span>
        <span>Retinal Intelligence for Earlier Detection and Better Health</span>
      </div>
    </div>
  </section>

  <!-- SECTION 5 — WHO WE HELP -->
  <section class="bg-brand-surface">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <PipeHeading level="h2" data-reveal>Who We Help</PipeHeading>
      <p class="mt-4 max-w-3xl text-lg text-brand-body leading-relaxed" data-reveal>
        Supporting providers, systems, and researchers across the care continuum.
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-4" data-reveal-group>
        <AudienceCard
          title="Primary Care Providers & Health Systems"
          body="Bring retinal screening directly into primary care—enabling earlier detection without specialist dependency."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/>
            <path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"/>
            <circle cx="20" cy="10" r="2"/>
          </svg>
        </AudienceCard>
        <AudienceCard
          title="Optometrists & Eye Care Professionals"
          body="Enhance diagnostic confidence with AI-supported interpretation and better visibility into subtle retinal findings."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </AudienceCard>
        <AudienceCard
          title="Insurance Providers & Population Health Programs"
          body="Close care gaps, improve screening rates, and support value-based care initiatives."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </AudienceCard>
        <AudienceCard
          title="Pharmaceutical & Clinical Research Organizations"
          body="Accelerate patient identification and clinical trial recruitment with advanced retinal intelligence."
        >
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 2v7.31"/>
            <path d="M14 9.3V1.99"/>
            <path d="M8.5 2h7"/>
            <path d="M14 9.3a6.5 6.5 0 1 1-4 0"/>
            <path d="M5.58 16.5h12.85"/>
          </svg>
        </AudienceCard>
      </div>
    </div>
  </section>

  <!-- SECTION 6 — TESTIMONIALS -->
  <section class="bg-brand-primary">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white" data-reveal>
        Proven Impact in Real-World Care
      </h2>
      <p class="mt-4 max-w-3xl mx-auto text-lg text-white/80 leading-relaxed" data-reveal>
        Our solutions are used by healthcare providers globally to expand access to screening, improve early detection, and prevent vision loss.
      </p>
      <div class="mt-12" data-reveal>
        <TestimonialFeature
          quote="Using Nsight360, we've screened over 250,000 patients and helped prevent thousands of cases of blindness."
          author="The Diabetic Center, Pakistan"
        />
      </div>
    </div>
  </section>

  <!-- SECTION 7 — LATEST RESOURCES -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <PipeHeading level="h2" data-reveal>Insights & Innovations</PipeHeading>
      <p class="mt-4 max-w-3xl text-lg text-brand-body leading-relaxed" data-reveal>
        Stay informed on the latest in AI, eye care, and early detection.
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-3" data-reveal-group>
        <ResourceCard
          categoryColor="accent"
          category="AI & Detection"
          title="The Role of AI in Early Disease Detection"
          excerpt="How foundation models are reshaping what frontline clinics can catch before symptoms ever appear."
          link="/resources"
        />
        <ResourceCard
          categoryColor="primary"
          category="Oculomics"
          title="Understanding Oculomics"
          excerpt="Why the retina is emerging as a window into cardiovascular, metabolic, and neurological health."
          link="/resources"
        />
        <ResourceCard
          categoryColor="secondary"
          category="Care Access"
          title="Closing the Diabetic Eye Care Gap"
          excerpt="Bringing retinal screening to populations that have historically been left out of specialist-driven care."
          link="/resources"
        />
      </div>

      <div class="mt-10 text-center">
        <a
          href="/resources"
          class="inline-flex items-center gap-2 text-brand-primary font-semibold hover:underline"
        >
          View All Resources
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 8 — CLOSING -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-3xl mx-auto px-6 md:px-8 lg:px-12 py-24 text-center">
