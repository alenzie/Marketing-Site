---
import Layout from '../components/layout/Layout.astro';
import ResourceCard from '../components/content/ResourceCard.astro';

const filters = ['All', 'News', 'Journal Articles', 'Insights'] as const;
---

<Layout
  title="Resources — Ophthalytics"
  description="Ophthalytics resources, news, testimonies, and more."
  currentPath="/resources"
>

  <!-- SECTION 1 — HERO -->
  <section class="bg-gradient-to-b from-brand-surface-blue to-white">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
      <h1 class="text-5xl md:text-6xl font-bold text-brand-ink leading-tight">
        Resources
      </h1>
      <p class="mt-6 max-w-2xl text-lg md:text-xl text-brand-body leading-relaxed">
        Ophthalytics resources, news, testimonies, and more.
      </p>

      <!-- STUB filter tabs — non-functional for pitch build -->
      <div class="mt-10 flex flex-wrap gap-2" data-filter-tabs>
        {filters.map((label, i) => (
          <button
            type="button"
            data-filter={label}
            aria-pressed={i === 0 ? 'true' : 'false'}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-semibold border transition',
              i === 0
                ? 'bg-brand-primary text-white border-brand-primary'
                : 'bg-white text-brand-body border-brand-line hover:border-brand-primary hover:text-brand-primary',
            ]}
          >
            {label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 2 — FEATURED RESOURCE -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <a
        href="https://www.mdpi.com/2075-4418/13/3/393"
        target="_blank"
        rel="noopener noreferrer"
        class="group grid gap-8 md:grid-cols-5 items-center rounded-2xl border border-brand-line overflow-hidden hover:shadow-lg transition-shadow"
      >
        <div class="md:col-span-2 aspect-video md:aspect-square relative bg-gradient-to-br from-brand-secondary to-brand-primary-light">
          <span class="absolute top-4 left-4 rounded-full bg-brand-secondary text-white text-xs font-semibold uppercase tracking-wider px-3 py-1">
            Journal Article
          </span>
          <div class="absolute inset-0 flex items-center justify-center text-white/80 text-sm font-medium">
            FINAL_ASSET_TBD — journal cover
          </div>
        </div>
        <div class="md:col-span-3 p-6 md:p-8">
          <p class="text-xs uppercase tracking-widest text-brand-muted font-semibold">Featured</p>
          <h2 class="mt-2 text-2xl md:text-3xl font-bold text-brand-ink leading-snug group-hover:text-brand-primary transition-colors">
            A Prospective Study on Diabetic Retinopathy Detection Based on Modified Convolutional Neural Network Using Fundus Images at Sindh Institute of Ophthalmology & Visual Sciences
          </h2>
          <p class="mt-4 text-base text-brand-body leading-relaxed">
            Peer-reviewed research authored by our founders.
          </p>
          <span class="mt-5 inline-flex items-center gap-2 text-brand-primary font-semibold">
            Read the Article
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- SECTION 3 — RESOURCES GRID -->
  <section class="bg-brand-surface">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <ResourceCard
          categoryColor="primary"
          category="News"
          title="Star Community Health Is Protecting Patients' Vision — One Routine Visit at a Time"
          excerpt="A closer look at how frontline community clinics are catching retinal disease earlier by folding screening into the regular primary-care visit."
          link="#"
        />
        <ResourceCard
          categoryColor="primary"
          category="News"
          title="Medicare Advantage News: What the 2026 Payment Increase Means for Medical Practices"
          excerpt="Policy changes that matter for clinics investing in preventive screening programs and value-based care contracts."
          link="#"
        />
        <ResourceCard
          categoryColor="warn"
          category="Awareness"
          title="Diabetes Awareness Month 2025: Ways to Participate as a Healthcare Provider"
          excerpt="Practical actions providers can take during awareness month to raise the standard of retinal care in their communities."
          link="#"
        />
        <ResourceCard
          categoryColor="accent"
          category="Insights"
          title="Our Innovation Pipeline: The Next Generation of Breakthroughs"
          excerpt="We're harnessing the power of deep-learning AI to enable retinal scans to detect more than just eye-related diseases."
          link="#"
        />
        <ResourceCard
          categoryColor="accent"
          category="Insights"
          title="Closing the Care Gap with 4Front360"
          excerpt="We are pioneering an autonomous version of our optical diagnostic breakthrough, NSight360, which can be administered and reported without the supervision of a physician. Successfully deployed for more than 150,000 patients in South Asia."
          link="#"
        />
        <ResourceCard
          categoryColor="accent"
          category="Insights"
          title="The Windows to 270 Diseases"
          excerpt="Retinal scans have emerged as an effective, non-invasive window into full-body health, offering insights on more than 270 systemic and chronic diseases."
          link="#"
        />
      </div>

      <div class="mt-12 text-center">
        <button
          type="button"
          class="inline-flex items-center gap-2 border-2 border-brand-primary text-brand-primary font-semibold px-6 py-3 rounded-md hover:bg-brand-primary hover:text-white transition"
        >
          Load More
        </button>
      </div>
    </div>
  </section>

</Layout>

<script>
  // STUB — filter tabs are non-functional for pitch build. Click shows active state but doesn't filter.
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-filter-tabs] button[data-filter]');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.setAttribute('aria-pressed', 'false');
        t.classList.remove('bg-brand-primary', 'text-white', 'border-brand-primary');
        t.classList.add('bg-white', 'text-brand-body', 'border-brand-line');
      });
      tab.setAttribute('aria-pressed', 'true');
      tab.classList.remove('bg-white', 'text-brand-body', 'border-brand-line');
      tab.classList.add('bg-brand-primary', 'text-white', 'border-brand-primary');
    });
  });
</script>
