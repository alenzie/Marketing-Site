---
// [DERIVED COPY — founder review needed before launch]
import Layout from '../../components/layout/Layout.astro';
import PipeHeading from '../../components/content/PipeHeading.astro';
import CapabilityTile from '../../components/content/CapabilityTile.astro';
import AudienceCard from '../../components/content/AudienceCard.astro';
import CtaBand from '../../components/content/CtaBand.astro';

const capabilities = [
  {
    title: 'AI-Powered Precision',
    body: 'Our deep-learning models are built on existing clinical practice guidelines to deliver fast, accurate assessments of diabetic retinopathy and other retinal conditions.',
    image: '/images/icons/brain.webp',
  },
  {
    title: 'Camera Agnostic',
    body: 'Nsight360 works seamlessly with any retinal camera—stationary or portable—from 30-degree to 200-degree fields of view. No lock-in. No proprietary hardware required.',
    image: '/images/icons/camera.webp',
  },
  {
    title: 'Portable & Easy to Deploy',
    body: 'Integrates with hand-held cameras so exams can happen anywhere—from a rural home health visit to a high-volume community clinic—without specialist presence.',
    image: '/images/icons/arrows.webp',
  },
];

const audiences = [
  { title: 'Primary Care Physicians', body: 'Add affordable, in-clinic retinal screening to your practice—creating a new revenue stream while closing a critical care gap.', image: '/images/audiences/primary-care-physicians.webp' },
  { title: 'Endocrinologists & Diabetologists', body: 'Identify patients with vision-threatening retinopathy in real time during routine diabetes care, then refer to specialists before sight is lost.', image: '/images/audiences/endocrinologists.webp' },
  { title: 'Nurses & Care Teams', body: "Perform screenings on-site or remotely without an on-site eye doctor. Nsight360's AI-assisted workflow fits team-based care models.", image: '/images/audiences/nurses.webp' },
  { title: 'Home Health Agencies', body: 'Bring retinal screening into the home. Add a new revenue source through diabetic retinopathy exams and improve HEDIS measures for underserved populations.', image: '/images/audiences/home-health.webp' },
  { title: 'Community Health Centers', body: 'Expand access to preventive screening in the communities that need it most—especially where specialty eye care is scarce or unaffordable.', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 21V9h6v12"/><path d="M12 3v6"/></svg>` },
  { title: 'Remote & Rural Clinics', body: "Overcome geography. Nsight360's handheld-compatible workflow enables eye screening in regions with no on-site ophthalmology coverage.", image: '/images/audiences/remote-rural.webp' },
];

const steps = [
  { n: '01', title: 'Capture', body: 'Any member of the care team uses a supported fundus camera to capture a retinal image.' },
  { n: '02', title: 'Upload', body: 'The image uploads securely to the Nsight360 platform via HIPAA-compliant transfer.' },
  { n: '03', title: 'AI + Expert Review', body: 'Our AI analyzes the image. A licensed ophthalmologist confirms findings and generates a clinical report.' },
  { n: '04', title: 'Report', body: 'Receive a clinically actionable report—complete with billing codes—within minutes. Refer, treat, or monitor.' },
];

const benefits = [
  { title: 'Flexible Pay-As-You-Go', body: 'No subscription fees. No long-term contracts. Pay only for the exams you perform.' },
  { title: 'Nationwide Ophthalmology Network', body: 'Our board-certified reading ophthalmologists are licensed across all 50 states, ready to confirm and sign off on diagnoses.' },
  { title: 'Patient Education Built In', body: 'Gen-AI powered communication tools help patients understand diabetic retinopathy and the importance of preventive care.' },
  { title: 'Training & Ongoing Support', body: 'Your team is fully trained on the platform, camera workflow, and clinical protocols—with continuous technical support on every deployment.' },
];
---

<Layout
  title="Nsight360 — Primary Care Retinal Screening — Ophthalytics"
  description="Nsight360 brings AI-assisted retinal screening to primary care, endocrinology, home health, and community clinics."
>
  <!-- SECTION 1 — HERO -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-28 grid gap-12 md:grid-cols-2 items-center">
      <div>
        <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">Primary Care Solution</p>
        <h1 class="mt-4 text-5xl md:text-6xl font-bold text-brand-ink leading-tight">Nsight360</h1>
        <p class="mt-3 text-2xl text-brand-primary" data-reveal>Retinal screening, delivered where care begins.</p>
        <p class="mt-6 max-w-xl text-lg text-brand-body leading-relaxed" data-reveal>
          Nsight360 brings AI-assisted retinal screening directly into primary care, endocrinology, home health, and community clinics—so at-risk patients are identified where they already receive care.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <button
            type="button"
            data-open-modal="demo"
            class="inline-flex items-center justify-center bg-brand-primary text-white font-semibold px-6 py-3 rounded-md hover:bg-brand-primary-dark transition"
          >
            Request a Demo
          </button>
          <a
            href="#who-its-for"
            class="inline-flex items-center justify-center border-2 border-brand-primary text-brand-primary font-semibold px-6 py-3 rounded-md hover:bg-brand-primary hover:text-white transition"
          >
            See Who It's For
          </a>
        </div>
      </div>
      <div class="flex justify-center">
        <img
          src="/images/hero/laptop-with-ai-scan.webp"
          alt="Laptop displaying an AI-assisted retinal scan"
          width="600"
          height="600"
          class="w-full max-w-[480px] h-auto"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- SECTION 2 — THE PROBLEM -->
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <PipeHeading level="h2" size="text-sm uppercase tracking-widest" color="text-brand-primary" data-reveal>
        THE CARE GAP
      </PipeHeading>
      <h2 class="mt-4 text-3xl md:text-4xl font-bold text-brand-ink" data-reveal>
        Millions of at-risk patients never reach a specialist.
      </h2>
      <div class="mt-6 space-y-5 text-lg text-brand-body leading-relaxed" data-reveal>
        <p>Diabetic retinopathy is the leading cause of preventable blindness in working-age adults. It is also one of the most treatable conditions—when caught early.</p>
        <p>But specialist shortages, long wait times, and travel barriers mean that millions of at-risk patients never make it in for an eye exam until symptoms appear. By then, intervention is harder and outcomes are worse.</p>
        <p>Primary care is where most of these patients already go. It is also where retinal screening has been hardest to deploy. Until now.</p>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — WHAT NSIGHT360 DOES -->
  <section class="bg-brand-surface">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 grid gap-12 md:grid-cols-5 items-start">
      <div class="md:col-span-3">
        <PipeHeading level="h2" size="text-sm uppercase tracking-widest" color="text-brand-primary" data-reveal>
          THE SOLUTION
        </PipeHeading>
        <h2 class="mt-4 text-3xl md:text-4xl font-bold text-brand-ink" data-reveal>
          Retinal screening built for the front line of care.
        </h2>
        <div class="mt-6 space-y-5 text-lg text-brand-body leading-relaxed" data-reveal>
          <p>
            Nsight360 enables non-specialists—primary care physicians, nurses, endocrinologists, home health aides—to capture retinal images using accessible hand-held or portable cameras. Our AI analyzes each image and produces a clinically actionable report, reviewed by licensed ophthalmologists, within minutes.
          </p>
          <p>
            No on-site eye specialist required. No workflow rebuild required. Just faster, broader access to sight-saving screening.
          </p>
        </div>
      </div>
      <div class="md:col-span-2 bg-white rounded-2xl shadow-md p-8 space-y-6">
        <div>
          <p class="text-5xl font-bold text-brand-primary">95%</p>
          <p class="mt-1 text-sm text-brand-body">Compliance rate providers can reach within 1 year</p>
        </div>
        <div class="border-t border-brand-line pt-6">
          <p class="text-5xl font-bold text-brand-primary">3x</p>
          <p class="mt-1 text-sm text-brand-body">Screening efficiency versus existing systems</p>
        </div>
        <div class="border-t border-brand-line pt-6">
          <p class="text-5xl font-bold text-brand-primary">50</p>
          <p class="mt-1 text-sm text-brand-body">US states where our reading ophthalmologists are licensed</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 4 — CAPABILITIES -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <div class="text-center max-w-3xl mx-auto">
        <PipeHeading level="h2" size="text-sm uppercase tracking-widest" color="text-brand-primary" class="justify-center" data-reveal>
          CAPABILITIES
        </PipeHeading>
        <h2 class="mt-4 text-3xl md:text-4xl font-bold text-brand-ink" data-reveal>What Makes Nsight360 Unique</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3" data-reveal-group>
        {capabilities.map((c) => (
          <CapabilityTile title={c.title} body={c.body}>
            <img
              slot="icon"
              src={c.image}
              alt=""
              width="96"
              height="96"
              class="w-12 h-12 object-contain"
              loading="lazy"
              decoding="async"
            />
          </CapabilityTile>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 5 — WHO IT'S FOR -->
  <section id="who-its-for" class="bg-brand-surface-blue">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <div class="text-center max-w-3xl mx-auto">
        <PipeHeading level="h2" color="text-brand-ink" class="justify-center" data-reveal>
          Built for Teams on the Front Line of Care
        </PipeHeading>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal-group>
        {audiences.map((a) => (
          <AudienceCard title={a.title} body={a.body}>
            {a.image ? (
              <img
                slot="icon"
                src={a.image}
                alt=""
                width="96"
                height="96"
                class="w-full h-full object-contain"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span slot="icon" set:html={a.icon}></span>
            )}
          </AudienceCard>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 6 — HOW IT WORKS -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink text-center" data-reveal>Simple, Fast, Integrated.</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-4" data-reveal-group>
        {steps.map((s) => (
          <div class="bg-white border border-brand-line rounded-xl p-6">
            <span class="text-brand-primary font-bold text-4xl">{s.n}</span>
            <h3 class="mt-3 text-lg font-semibold text-brand-ink">{s.title}</h3>
            <p class="mt-2 text-sm text-brand-body leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 7 — WHY -->
  <CtaBand>
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <h2 class="text-3xl md:text-4xl font-bold text-center" data-reveal>Designed for Real-World Care</h2>
      <div class="mt-12 grid gap-8 md:grid-cols-2 max-w-5xl mx-auto" data-reveal-group>
        {benefits.map((b) => (
          <div>
            <h3 class="text-xl font-bold">{b.title}</h3>
            <p class="mt-2 text-base text-white/90 leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </CtaBand>

  <!-- SECTION 8 — FINAL CTA -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-4xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink" data-reveal>
        Close the diabetic eye care gap—where your patients already are.
      </h2>
      <p class="mt-5 max-w-2xl mx-auto text-lg text-brand-body leading-relaxed" data-reveal>
        See Nsight360 in action with a personalized demo for your clinic, system, or program.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center" data-reveal>
        <button
          type="button"
          data-open-modal="demo"
          class="inline-flex items-center justify-center bg-brand-primary text-white font-semibold px-6 py-3 rounded-md hover:bg-brand-primary-dark transition"
        >
          Request a Demo
        </button>
        <button
          type="button"
          data-open-modal="contact"
          class="inline-flex items-center justify-center border-2 border-brand-primary text-brand-primary font-semibold px-6 py-3 rounded-md hover:bg-brand-primary hover:text-white transition"
        >
          Contact Us
        </button>
      </div>
    </div>
  </section>
</Layout>
