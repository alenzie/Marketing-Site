---
import Layout from '../../components/layout/Layout.astro';
import ProductCard from '../../components/content/ProductCard.astro';

const products = [
  {
    slug: 'nsight360',
    eyebrow: 'HUMAN + AI',
    name: 'Nsight360',
    tagline: 'AI-assisted retinal screening for primary care, health systems, and insurance providers.',
    capabilities: [
      'Primary care integration',
      'Human + AI workflow',
      'Scalable screening programs',
    ],
  },
  {
    slug: '2nd-opinion',
    eyebrow: 'EYE CARE MARKET',
    name: '2nd Opinion',
    tagline: 'AI-enhanced diagnostic support for optometrists and eye care professionals.',
    capabilities: [
      'Lesion visualization',
      'Diagnostic confidence',
      'Workflow integration',
    ],
  },
  {
    slug: 'ophthal360',
    eyebrow: 'AUTONOMOUS AI',
    name: 'Ophthal360',
    tagline: 'Autonomous retinal diagnostics for high-volume screening programs and global markets.',
    capabilities: [
      'Autonomous detection',
      'High-throughput screening',
      'Automated referral logic',
    ],
  },
];
---

<Layout
  title="Solutions — Ophthalytics"
  description="Four retinal AI solutions, one foundational platform. Ophthalytics builds AI that turns retinal images into actionable diagnostic intelligence."
>
  <!-- SECTION 1 — HERO -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-28">
      <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">Our Solutions</p>
      <h1 class="mt-3 text-5xl md:text-6xl font-bold text-brand-ink leading-tight max-w-4xl">
        Four Retinal AI Solutions.<br/>One Foundational Platform.
      </h1>
      <p class="mt-6 max-w-3xl text-lg md:text-xl text-brand-body leading-relaxed" data-reveal>
        Ophthalytics builds AI that turns a retinal image into actionable diagnostic intelligence—purpose-built for every point in the care continuum, from primary care screening to clinical research.
      </p>
    </div>
  </section>

  <!-- SECTION 2 — FLAGSHIP -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <div class="grid gap-0 md:grid-cols-2 rounded-2xl overflow-hidden border border-brand-line">
        <div class="bg-gradient-to-br from-[#0F2C5C] via-[#123F6E] to-[#0F6F7D] p-10 md:p-12 flex items-center justify-center min-h-[380px]">
          <svg viewBox="0 0 300 300" class="w-full max-w-[300px]" aria-hidden="true">
            <defs>
              <radialGradient id="core" cx="50%" cy="50%">
                <stop offset="0%" stop-color="#0EA5E9" stop-opacity="0.8"/>
                <stop offset="100%" stop-color="#0EA5E9" stop-opacity="0.1"/>
              </radialGradient>
            </defs>
            <circle cx="150" cy="150" r="60" fill="url(#core)"/>
            <circle cx="150" cy="150" r="40" fill="#0EA5E9" fill-opacity="0.3" stroke="#fff" stroke-width="1.5"/>
            <text x="150" y="155" text-anchor="middle" fill="#fff" font-size="14" font-weight="700" font-family="Inter">Ocula360</text>
            {[
              { x: 150, y: 50, label: 'Nsight360' },
              { x: 60, y: 210, label: '2nd Opinion' },
              { x: 240, y: 210, label: 'Ophthal360' },
            ].map((n) => (
              <g>
                <line x1="150" y1="150" x2={n.x} y2={n.y} stroke="#fff" stroke-opacity="0.4" stroke-dasharray="3 4"/>
                <circle cx={n.x} cy={n.y} r="28" fill="#fff" fill-opacity="0.08" stroke="#fff" stroke-opacity="0.6" stroke-width="1"/>
                <text x={n.x} y={n.y + 4} text-anchor="middle" fill="#fff" font-size="10" font-weight="600" font-family="Inter">{n.label}</text>
              </g>
            ))}
          </svg>
        </div>
        <div class="p-10 md:p-12 flex flex-col justify-center">
          <span class="inline-block self-start rounded-full bg-brand-primary/10 text-brand-primary text-xs font-semibold uppercase tracking-widest px-3 py-1">
            Flagship
          </span>
          <h2 class="mt-5 text-4xl md:text-5xl font-bold text-brand-ink">Ocula360</h2>
          <p class="mt-2 text-2xl text-brand-primary leading-tight">Foundational Retinal AI</p>
          <p class="mt-5 text-base text-brand-body leading-relaxed">
            Our flagship AI engine, built on a foundational model architecture to detect multiple retinal diseases from a single image. Ocula360 powers scalable screening, advanced DRSS scoring, and future-ready multimodal applications across clinical care and research.
          </p>
          <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-brand-ink">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span>Multi-Disease Detection</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span>DRSS Scoring</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span>Explainable &amp; Multimodal</li>
          </ul>
          <a
            href="/solutions/ocula360"
            class="mt-7 inline-flex items-center gap-2 text-brand-primary font-semibold hover:gap-3 transition-all"
          >
            Learn more about Ocula360
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 3 — THREE-PRODUCT GRID -->
  <section class="bg-brand-surface">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20">
      <div class="text-center max-w-3xl mx-auto">
        <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold" data-reveal>Purpose-Built Solutions</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-bold text-brand-ink" data-reveal>Tailored for Every Point of Care</h2>
        <p class="mt-4 text-lg text-brand-body leading-relaxed" data-reveal>
          Each solution extends Ocula360's foundational intelligence into a specific care environment.
        </p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3" data-reveal-group>
        {products.map((p) => (
          <a href={`/solutions/${p.slug}`} class="group transition-transform hover:-translate-y-1">
            <ProductCard
              eyebrow={p.eyebrow}
              name={p.name}
              tagline={p.tagline}
              capabilities={p.capabilities}
            />
            <span class="mt-4 inline-flex items-center gap-1 text-brand-primary font-semibold">
              Learn more <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 4 — WORK TOGETHER -->
  <section class="bg-white">
    <div class="max-w-5xl mx-auto px-6 md:px-8 lg:px-12 py-20 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink" data-reveal>One Platform. Four Deployments.</h2>
      <p class="mt-5 text-lg text-brand-body leading-relaxed max-w-3xl mx-auto" data-reveal>
        Ocula360 is the foundation. Nsight360, 2nd Opinion, and Ophthal360 are purpose-built deployments of that foundation, each tuned for the workflows, decision points, and volume of a specific care setting.
      </p>
      <div class="mt-12 flex justify-center">
        <svg viewBox="0 0 500 340" class="w-full max-w-[500px]" aria-hidden="true">
          <circle cx="250" cy="170" r="60" fill="#1E3A8A"/>
          <text x="250" y="170" text-anchor="middle" fill="#fff" font-size="16" font-weight="700" font-family="Inter">Ocula360</text>
          <text x="250" y="190" text-anchor="middle" fill="#fff" fill-opacity="0.8" font-size="10" font-family="Inter">Foundation</text>
          {[
            { x: 250, y: 40, label: 'Nsight360', sub: 'Primary care' },
            { x: 70, y: 280, label: '2nd Opinion', sub: 'Optometry' },
            { x: 430, y: 280, label: 'Ophthal360', sub: 'Autonomous / scale' },
          ].map((n) => (
            <g>
              <line x1="250" y1="170" x2={n.x} y2={n.y} stroke="#3B5BBF" stroke-width="1.5" stroke-dasharray="4 4"/>
              <circle cx={n.x} cy={n.y} r="42" fill="#EFF6FF" stroke="#1E3A8A" stroke-width="1.5"/>
              <text x={n.x} y={n.y - 2} text-anchor="middle" fill="#0F172A" font-size="12" font-weight="700" font-family="Inter">{n.label}</text>
              <text x={n.x} y={n.y + 14} text-anchor="middle" fill="#64748B" font-size="10" font-family="Inter">{n.sub}</text>
            </g>
          ))}
        </svg>
      </div>
    </div>
  </section>

  <!-- SECTION 5 — FINAL CTA -->
  <section class="bg-brand-primary text-white">
    <div class="max-w-4xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 text-center">
      <h2 class="text-3xl md:text-4xl font-bold" data-reveal>Find the right solution for your organization.</h2>
      <p class="mt-5 max-w-2xl mx-auto text-lg text-white/90 leading-relaxed" data-reveal>
        Whether you're screening at the point of care, supporting diagnosis, or running a clinical trial, we'll help you identify which solution fits your workflow.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center" data-reveal>
        <button
          type="button"
          data-open-modal="demo"
          class="inline-flex items-center justify-center bg-white text-brand-primary font-semibold px-6 py-3 rounded-md hover:bg-brand-surface transition"
        >
          Request a Demo
        </button>
        <button
          type="button"
          data-open-modal="contact"
          class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-white hover:text-brand-primary transition"
        >
          Contact Us
        </button>
      </div>
    </div>
  </section>
</Layout>
