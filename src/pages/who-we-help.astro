---
import Layout from '../components/layout/Layout.astro';
import PipeHeading from '../components/content/PipeHeading.astro';
import AudiencePill from '../components/content/AudiencePill.astro';
import CtaBand from '../components/content/CtaBand.astro';
---

<Layout
  title="Who We Help — Ophthalytics"
  description="Advancing eye care across every stage of the patient journey."
  currentPath="/who-we-help"
>

  <!-- SECTION 1 — HERO BAND -->
  <section class="relative overflow-hidden bg-gradient-to-b from-brand-surface-blue to-white">
    <svg class="absolute inset-0 w-full h-full opacity-[0.12] pointer-events-none" aria-hidden="true">
      <defs>
        <pattern id="wwh-dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.5" fill="#1E3A8A" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#wwh-dots)" />
    </svg>
    <div class="relative max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-24 md:py-32">
      <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">Who We Help</p>
      <h1 class="mt-4 text-5xl md:text-6xl font-bold text-brand-ink leading-tight max-w-4xl">
        Advancing Eye Care Across Every Stage of the Patient Journey
      </h1>
    </div>
  </section>

  <!-- SECTION 2 — INTRO STATEMENT -->
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 md:px-8 lg:px-12 py-20 text-center space-y-6">
      <p class="text-lg md:text-xl text-brand-body leading-relaxed" data-reveal>
        Ophthalytics supports healthcare providers, researchers, and organizations through AI-powered solutions designed for screening, diagnosis, and clinical research.
      </p>
      <p class="text-lg md:text-xl text-brand-body leading-relaxed" data-reveal>
        From primary care to optometry to pharmaceutical trials, our products are built to address real-world gaps in detection, decision-making, and patient access.
      </p>
    </div>
  </section>

  <!-- SECTION 3 — NSIGHT360 BLOCK -->
  <section class="bg-brand-surface">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-6">
        <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">Nsight360</p>
        <p class="text-sm text-brand-body italic">For Primary Care, Population Health, and Screening Programs</p>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink leading-tight max-w-3xl" data-reveal>
        Bringing retinal screening to the frontlines of care
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-brand-body leading-relaxed" data-reveal>
        Nsight360 is designed for healthcare providers who want to deliver accessible, efficient retinal screening at the point of care. By enabling non-specialists to perform eye exams, it expands access and helps close critical care gaps.
      </p>

      <div class="mt-10 grid gap-10 md:grid-cols-2">
        <div>
          <h3 class="text-xl font-semibold text-brand-ink mb-4">Who it's for</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <AudiencePill label="Primary Care Physicians" photo="/images/audiences/Primary-Care-Physicians.png" photoAlt="Primary care physician" />
            <AudiencePill label="Endocrinologists & Diabetologists" photo="/images/audiences/Endocrinologists-and-Diabetologists.png" photoAlt="Endocrinologist consultation" />
            <AudiencePill label="Nurses & Care Teams" photo="/images/audiences/Nurses-and-Educators.png" photoAlt="Nurses and educators" />
            <AudiencePill label="Home Health Agencies" photo="/images/audiences/Home-Health-Agencies.png" photoAlt="Home health visit" />
            <AudiencePill label="Community Health Centers" photo="/images/audiences/Medical-Schools.png" photoAlt="Community health center staff" />
            <AudiencePill label="Remote & Rural Clinics" photo="/images/audiences/Remote-and-Rural-Eye-Clinics.png" photoAlt="Remote and rural clinic" />
          </div>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-brand-ink mb-4">How it helps</h3>
          <ul class="space-y-3 text-base text-brand-body leading-relaxed">
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Enables retinal screening without requiring an on-site eye specialist</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Expands access to underserved populations</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Supports early detection of diabetic retinopathy</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Improves workflow efficiency and patient throughput</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Helps close care gaps and improve quality measures</span></li>
          </ul>
        </div>
      </div>
      <p class="mt-10 italic text-brand-body max-w-3xl">
        Nsight360 makes it possible to identify at-risk patients earlier—where they already receive care.
      </p>
    </div>
  </section>

  <!-- SECTION 3.5 — COMPLIANCE STAT (visual break) -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-12 md:py-16">
      <div class="rounded-2xl overflow-hidden border border-brand-line bg-brand-surface-blue/40">
        <img
          src="/images/sections/95-compliance-rate.png"
          alt="95% compliance rate — diabetic retinopathy screening with Nsight360"
          class="w-full h-auto"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- SECTION 4 — 2ND OPINION BLOCK -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-6">
        <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">2nd Opinion</p>
        <p class="text-sm text-brand-body italic">For Optometrists and Eye Care Professionals</p>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink leading-tight max-w-3xl" data-reveal>
        Enhancing confidence in retinal assessments
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-brand-body leading-relaxed" data-reveal>
        2nd Opinion is built for optometrists and eye care providers who want additional support in interpreting retinal images, especially in complex or borderline cases.
      </p>

      <div class="mt-10 grid gap-10 md:grid-cols-2">
        <div>
          <h3 class="text-xl font-semibold text-brand-ink mb-4">Who it's for</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <AudiencePill label="Optometrists" photo="/images/audiences/Ophthalmologists.png" photoAlt="Optometrist with patient" />
            <AudiencePill label="Eye Clinics & Optical Chains" photo="/images/audiences/Remote-and-Rural-Eye-Clinics.png" photoAlt="Eye clinic" />
            <AudiencePill label="Ophthalmology Practices" photo="/images/audiences/Ophthalmologists.png" photoAlt="Ophthalmologist" />
            <AudiencePill label="Reading Centers" photo="/images/audiences/Medical-Schools.png" photoAlt="Reading center" />
          </div>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-brand-ink mb-4">How it helps</h3>
          <ul class="space-y-3 text-base text-brand-body leading-relaxed">
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Highlights suspicious regions and potential lesions</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Supports clinical decision-making in uncertain cases</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Reduces variability in retinal interpretation</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Integrates seamlessly into existing workflows</span></li>
          </ul>
        </div>
      </div>
      <p class="mt-10 italic text-brand-body max-w-3xl">
        In everyday practice, not every case is clear-cut. 2nd Opinion provides an added layer of insight—helping clinicians see more and decide with greater confidence.
      </p>
    </div>
  </section>

  <!-- SECTION 5 — OPHTHAL360 BLOCK -->
  <section class="bg-brand-surface">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-6">
        <p class="text-sm uppercase tracking-widest text-brand-primary font-semibold">Ophthal360</p>
        <p class="text-sm text-brand-body italic">For High-Volume Screening and Autonomous Deployment</p>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink leading-tight max-w-3xl" data-reveal>
        Autonomous AI for scale and reach
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-brand-body leading-relaxed" data-reveal>
        Ophthal360 is designed for organizations delivering retinal screening at scale—healthcare systems, large screening programs, and partners serving high-volume markets. Currently in active deployment in Asian markets, Ophthal360 enables rapid, consistent detection with minimal manual intervention.
      </p>

      <div class="mt-10 grid gap-10 md:grid-cols-2">
        <div>
          <h3 class="text-xl font-semibold text-brand-ink mb-4">Who it's for</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <AudiencePill label="Healthcare Systems" photo="/images/audiences/Home-Health-Agencies.png" photoAlt="Healthcare system facility" />
            <AudiencePill label="Population Health Programs" photo="/images/audiences/Nurses-and-Educators.png" photoAlt="Population health care team" />
            <AudiencePill label="Pharmaceutical Companies" photo="/images/audiences/Pharmaceutical-Companies.png" photoAlt="Pharmaceutical research" />
            <AudiencePill label="Clinical Research Organizations" photo="/images/audiences/Medical-Schools.png" photoAlt="Clinical research staff" />
            <AudiencePill label="Imaging Centers" photo="/images/audiences/Device-Manufacturers.png" photoAlt="Imaging device" />
            <AudiencePill label="Academic & Research Institutions" photo="/images/audiences/Medical-Schools.png" photoAlt="Academic research" />
          </div>
        </div>
        <div>
          <h3 class="text-xl font-semibold text-brand-ink mb-4">How it helps</h3>
          <ul class="space-y-3 text-base text-brand-body leading-relaxed">
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Performs retinal analysis and generates screening outputs without manual interpretation</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Optimized for large-scale deployment in clinics, screening programs, and population health initiatives</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Identifies at-risk patients and supports timely referral decisions</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Accelerates recruitment and enrollment timelines for trials</span></li>
            <li class="flex gap-3"><span class="text-brand-primary mt-1">•</span><span>Supports consistent evaluation across sites and geographies</span></li>
          </ul>
        </div>
      </div>
      <p class="mt-10 italic text-brand-body max-w-3xl">
        Ophthal360 makes it possible to deliver screening coverage at a scale no specialist-dependent model can match.
      </p>
    </div>
  </section>

  <!-- SECTION 6 — CONTINUUM OF CARE -->
  <section class="bg-white">
    <div class="max-w-4xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-ink leading-tight" data-reveal>
        From Screening to Diagnosis to Discovery
      </h2>
      <p class="mt-6 text-lg text-brand-body max-w-3xl mx-auto leading-relaxed" data-reveal>
        Together, our products support the full continuum of eye care:
      </p>

      <div class="mt-12 grid gap-8 md:grid-cols-3 relative" data-reveal-group>
        <!-- Step 1 -->
        <a href="/solutions/nsight360" class="flex flex-col items-center text-center p-4 rounded-xl hover:bg-brand-surface transition-colors group">
          <div class="w-16 h-16 rounded-full bg-brand-surface-blue text-brand-primary flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/><path d="M11 8v6"/></svg>
          </div>
          <p class="mt-4 text-sm uppercase tracking-widest text-brand-muted font-semibold">Screening</p>
          <p class="mt-1 text-lg font-bold text-brand-primary">Nsight360</p>
          <p class="mt-3 text-sm text-brand-body leading-relaxed">Bring retinal screening to the frontlines of care.</p>
        </a>
        <!-- Step 2 -->
        <a href="/solutions/2nd-opinion" class="flex flex-col items-center text-center p-4 rounded-xl hover:bg-brand-surface transition-colors group">
          <div class="w-16 h-16 rounded-full bg-brand-surface-blue text-brand-primary flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <p class="mt-4 text-sm uppercase tracking-widest text-brand-muted font-semibold">Diagnostic Support</p>
          <p class="mt-1 text-lg font-bold text-brand-primary">2nd Opinion</p>
          <p class="mt-3 text-sm text-brand-body leading-relaxed">Enhance clinical confidence in complex cases.</p>
        </a>
        <!-- Step 3 -->
        <a href="/solutions/ophthal360" class="flex flex-col items-center text-center p-4 rounded-xl hover:bg-brand-surface transition-colors group">
          <div class="w-16 h-16 rounded-full bg-brand-surface-blue text-brand-primary flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <p class="mt-4 text-sm uppercase tracking-widest text-brand-muted font-semibold">Scale & Discovery</p>
          <p class="mt-1 text-lg font-bold text-brand-primary">Ophthal360</p>
          <p class="mt-3 text-sm text-brand-body leading-relaxed">Autonomous screening for high-volume programs.</p>
        </a>
      </div>

      <p class="mt-12 text-lg text-brand-body leading-relaxed">
        This integrated approach enables earlier detection, better decisions, and faster advancements in eye health.
      </p>
    </div>
  </section>

  <!-- SECTION 7 — REGIONAL IMPACT -->
  <section class="bg-brand-surface-blue">
    <div class="max-w-6xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 grid gap-12 md:grid-cols-2 items-center">
      <div class="rounded-2xl overflow-hidden shadow-lg">
        <img
          src="/images/sections/pakistan-collage.jpg"
          alt="Ophthalytics team with The Diabetes Centre partners in Pakistan"
          class="block w-full h-auto"
          loading="lazy"
        />
      </div>
      <div>
        <PipeHeading level="h2" data-reveal>Regional Impact</PipeHeading>
        <h3 class="mt-4 text-3xl md:text-4xl font-bold text-brand-ink leading-tight" data-reveal>
          Transforming Diabetic Eye Care in Pakistan
        </h3>
        <p class="mt-6 text-base md:text-lg text-brand-body leading-relaxed" data-reveal>
          Recognizing the crucial need to reach underserved communities, we have forged powerful partnerships to amplify our impact. Through dynamic collaborations with The Diabetes Centre and the Layton Rahmatulla Benevolent Trust, we are bringing our services to rural and marginalized populations in Pakistan. By harnessing Nsight360, we are breaking down barriers to access, ensuring that individuals in these communities receive the essential diabetic eye exams they deserve.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION 8 — FINAL CTA -->
  <CtaBand>
    <div class="max-w-7xl mx-auto px-6 md:px-8 lg:px-12 py-20 md:py-24 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight" data-reveal>
        Find the Right Solution for Your Practice
      </h2>
      <p class="mt-6 max-w-2xl mx-auto text-lg text-white/90 leading-relaxed" data-reveal>
        Whether you are delivering care, supporting diagnosis, or advancing research, Ophthalytics provides AI-powered tools designed for your needs.
      </p>
      <div class="mt-8" data-reveal>
        <button
          type="button"
          data-open-modal="demo"
          class="inline-flex items-center justify-center bg-white text-brand-primary font-semibold px-8 py-3 rounded-md hover:bg-brand-surface transition"
        >
          Schedule a Demo
        </button>
      </div>
    </div>
  </CtaBand>

</Layout>
