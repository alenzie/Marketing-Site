---
interface Props {
  class?: string;
  size?: number | string;
  tone?: "cyan" | "white" | "navy" | "current";
}

const { class: className = "", size = 24, tone = "cyan" } = Astro.props;

const toneClass =
  tone === "cyan"
    ? "text-brand-cyan"
    : tone === "white"
    ? "text-white"
    : tone === "navy"
    ? "text-brand-navy"
    : "";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  class={`${toneClass} ${className}`.trim()}
>
  <rect x="6" y="6" width="16" height="12" rx="2" />
  <rect x="10" y="12" width="16" height="12" rx="2" opacity="0.7" />
  <circle cx="18" cy="18" r="2.2" fill="currentColor" stroke="none" />
</svg>
