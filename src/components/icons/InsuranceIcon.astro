---
interface Props {
  class?: string;
  size?: number | string;
  tone?: "cyan" | "white" | "navy" | "current";
}

const { class: className = "", size = 24, tone = "cyan" } = Astro.props;

const toneClass =
  tone === "cyan"
    ? "text-brand-cyan"
    : tone === "white"
    ? "text-white"
    : tone === "navy"
    ? "text-brand-navy"
    : "";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 32 32"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  class={`${toneClass} ${className}`.trim()}
>
  <path d="M16 4 L 26 8 V 16 Q 26 24 16 28 Q 6 24 6 16 V 8 Z" />
  <circle cx="16" cy="16" r="4.5" />
  <circle cx="16" cy="16" r="1.25" fill="currentColor" stroke="none" />
</svg>
