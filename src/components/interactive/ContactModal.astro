---
import Modal from './Modal.astro';
import FormBlock from './FormBlock.astro';
---

<Modal name="contact" labelledBy="contact-modal-title" describedBy="contact-modal-desc" size="md">
  <p class="text-xs uppercase tracking-widest text-brand-primary font-semibold">
    Ophthalytics
  </p>
  <h2 id="contact-modal-title" class="mt-2 text-2xl md:text-3xl font-bold text-brand-ink">
    Connect With Us
  </h2>
  <p id="contact-modal-desc" class="mt-2 text-brand-body">
    Submit the form, and a member of our team will follow up with you shortly.
  </p>

  <FormBlock logPrefix="CONTACT" successMessage="Thanks! We'll be in touch shortly." class="mt-6 space-y-4">
    <div>
      <label for="contact-name" class="block text-sm font-medium text-brand-ink mb-1">
        Name <span class="text-status-error">*</span>
      </label>
      <input
        id="contact-name"
        name="name"
        type="text"
        required
        class="w-full px-4 py-2.5 rounded-md border border-brand-line focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition"
      />
    </div>
    <div>
      <label for="contact-email" class="block text-sm font-medium text-brand-ink mb-1">
        Email <span class="text-status-error">*</span>
      </label>
      <input
        id="contact-email"
        name="email"
        type="email"
        required
        class="w-full px-4 py-2.5 rounded-md border border-brand-line focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition"
      />
    </div>
    <div>
      <label for="contact-message" class="block text-sm font-medium text-brand-ink mb-1">
        Message <span class="text-status-error">*</span>
      </label>
      <textarea
        id="contact-message"
        name="message"
        rows="5"
        required
        class="w-full px-4 py-2.5 rounded-md border border-brand-line focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition resize-y"
      ></textarea>
    </div>
    <button
      type="submit"
      class="w-full bg-brand-primary text-white font-semibold px-6 py-3 rounded-md hover:bg-brand-primary-dark transition"
    >
      Send Message
    </button>
  </FormBlock>
</Modal>
