---
interface Props {
  image?: string;
  id?: string;
  class?: string;
}
const {
  image = '/images/sections/ai-geometrcicdesign.jpg',
  id,
  class: className = '',
} = Astro.props;
---
<!-- Change 5: washed-out background photo behind the gradient (3-layer recipe) -->
<section
  id={id}
  class:list={['relative text-white overflow-hidden isolate', className]}
  style="background: linear-gradient(135deg, #0F2C5C 0%, #1E3A8A 50%, #0E7FB0 100%);"
>
  <!-- Layer 1: background photo, luminosity blend -->
  <img
    src={image}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center pointer-events-none"
    style="opacity:0.18;mix-blend-mode:luminosity;"
    loading="lazy"
  />
  <!-- Layer 2: wash overlay -->
  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background:radial-gradient(ellipse at center, rgba(15,44,92,0.3) 0%, rgba(15,44,92,0.7) 100%), linear-gradient(to bottom, rgba(30,58,138,0.4) 0%, rgba(14,127,176,0.4) 100%);"
  ></div>
  <!-- Layer 3: content -->
  <div class="relative z-[2]">
    <slot />
  </div>
</section>
