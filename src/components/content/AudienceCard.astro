---
interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<div class="bg-white rounded-lg p-6 text-center">
  <div class="w-24 h-24 rounded-full overflow-hidden bg-brand-surface-blue flex items-center justify-center mb-5 mx-auto text-brand-primary">
    <slot name="icon" />
  </div>
  <h3 class="text-lg font-semibold text-brand-ink mb-2">{title}</h3>
  <p class="text-sm text-brand-body leading-relaxed">{body}</p>
</div>
