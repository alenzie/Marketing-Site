---
interface Props {
  quote: string;
  author: string;
}

const { quote, author } = Astro.props;
---

<blockquote class="max-w-4xl mx-auto text-center">
  <p class="text-2xl md:text-3xl font-medium text-white leading-snug">
    &ldquo;{quote}&rdquo;
  </p>
  <footer class="mt-6 text-brand-secondary text-base">
    &mdash; {author}
  </footer>
</blockquote>
