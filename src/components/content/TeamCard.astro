---
interface Props {
  name: string;
  role: string;
  headshot?: string;
  bioLink?: string;
  bioModal?: string;
  size?: 'lg' | 'sm';
}

const { name, role, headshot, bioLink, bioModal, size = 'lg' } = Astro.props;

const sizeClass =
  size === 'sm'
    ? 'w-24 h-24 md:w-28 md:h-28'
    : 'w-32 h-32 md:w-40 md:h-40';

const initials = name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0])
  .join('')
  .toUpperCase();
---

<div class="text-center">
  {headshot ? (
    <img
      src={headshot}
      alt={name}
      class:list={[sizeClass, 'rounded-full mx-auto object-cover border-4 border-white shadow-md']}
    />
  ) : (
    <div
      class:list={[
        sizeClass,
        'rounded-full mx-auto flex items-center justify-center bg-brand-surface-blue text-brand-primary font-bold text-2xl border-4 border-white shadow-md',
      ]}
      aria-hidden="true"
    >
      {initials}
    </div>
  )}
  <h3 class={size === 'sm' ? 'text-lg font-bold text-brand-ink mt-4' : 'text-xl font-bold text-brand-ink mt-4'}>
    {name}
  </h3>
  <p class="text-sm text-brand-primary mt-1">{role}</p>
  {bioModal ? (
    <button
      type="button"
      data-open-modal={bioModal}
      class="inline-block mt-3 px-4 py-2 rounded-md border border-brand-primary text-brand-primary text-sm font-semibold hover:bg-brand-primary hover:text-white transition"
    >
      Read Bio
    </button>
  ) : bioLink && (
    <a
      href={bioLink}
      class="inline-block mt-3 px-4 py-2 rounded-md border border-brand-primary text-brand-primary text-sm font-semibold hover:bg-brand-primary hover:text-white transition"
    >
      Read Bio
    </a>
  )}
</div>
