---
interface SubItem {
  name: string;
  href: string;
  icon?: string;
}

interface NavEntry {
  type: 'link' | 'group';
  label: string;
  href: string;
  items?: SubItem[];
}

interface Props {
  nav: NavEntry[];
  currentPath: string;
}

const { nav, currentPath } = Astro.props;

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');
const isGroupActive = (entry: NavEntry) =>
  isActive(entry.href) || (entry.items?.some((i) => isActive(i.href)) ?? false);
---

<div
  id="mobile-drawer"
  data-mobile-drawer
  hidden
  class="md:hidden fixed inset-0 z-50"
  aria-hidden="true"
>
  <div data-drawer-overlay class="absolute inset-0 bg-brand-ink/60"></div>
  <aside
    data-drawer-panel
    role="dialog"
    aria-modal="true"
    aria-label="Site navigation"
    class="absolute right-0 top-0 bottom-0 w-[min(88vw,360px)] bg-white shadow-2xl translate-x-full transition-transform duration-200 ease-out flex flex-col"
  >
    <div class="flex items-center justify-between px-5 py-4 border-b border-brand-line">
      <a href="/" aria-label="Ophthalytics home" data-drawer-link>
        <img
          src="/ophthalytics-logo.svg"
          alt="Ophthalytics"
          width="300"
          height="34"
          class="h-8 w-auto"
        />
      </a>
      <button
        type="button"
        data-drawer-close
        aria-label="Close navigation menu"
        class="inline-flex items-center justify-center w-10 h-10 rounded-md text-brand-ink hover:bg-brand-surface"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Mobile navigation">
      <ul class="flex flex-col gap-1">
        {nav.map((entry) => (
          entry.type === 'link' ? (
            <li>
              <a
                href={entry.href}
                data-drawer-link
                class:list={[
                  'block px-4 py-3 rounded-md text-base font-medium',
                  isActive(entry.href)
                    ? 'bg-brand-surface-blue text-brand-primary'
                    : 'text-brand-body hover:bg-brand-surface',
                ]}
                aria-current={isActive(entry.href) ? 'page' : undefined}
              >
                {entry.label}
              </a>
            </li>
          ) : (
            <li data-drawer-group>
              <button
                type="button"
                data-drawer-accordion
                aria-expanded={isGroupActive(entry) ? 'true' : 'false'}
                class:list={[
                  'w-full flex items-center justify-between px-4 py-3 rounded-md text-base font-medium',
                  isGroupActive(entry)
                    ? 'bg-brand-surface-blue text-brand-primary'
                    : 'text-brand-body hover:bg-brand-surface',
                ]}
              >
                <span>{entry.label}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform duration-200"
                  data-drawer-chevron
                  style={isGroupActive(entry) ? 'transform: rotate(180deg);' : ''}
                >
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <ul
                data-drawer-submenu
                hidden={!isGroupActive(entry)}
                class="pl-4 pt-1 pb-2 flex flex-col gap-1"
              >
                <li>
                  <a
                    href={entry.href}
                    data-drawer-link
                    class:list={[
                      'block px-4 py-2 rounded-md text-sm font-semibold',
                      isActive(entry.href)
                        ? 'text-brand-primary'
                        : 'text-brand-body hover:text-brand-primary',
                    ]}
                  >
                    {entry.label} overview →
                  </a>
                </li>
                {entry.items?.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      data-drawer-link
                      class:list={[
                        'flex items-center gap-3 px-4 py-2 rounded-md text-sm',
                        isActive(item.href)
                          ? 'text-brand-primary font-semibold'
                          : 'text-brand-body hover:text-brand-primary',
                      ]}
                      aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                      {item.icon && (
                        <img
                          src={item.icon}
                          alt=""
                          width="40"
                          height="40"
                          class="w-5 h-5 flex-shrink-0 object-contain"
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                      <span>{item.name}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          )
        ))}
        <li class="pt-3">
          <button
            type="button"
            data-open-modal="contact"
            data-drawer-link
            class="w-full block px-4 py-3 rounded-md text-base font-semibold text-white bg-brand-primary hover:bg-brand-primary/90 transition"
          >
            Contact
          </button>
        </li>
      </ul>
    </nav>

    <div class="border-t border-brand-line px-5 py-4 text-sm text-brand-body space-y-1">
      <a href="mailto:info@ophthalytics.com" class="block hover:text-brand-primary">
        info@ophthalytics.com
      </a>
      <a href="tel:+18622226880" class="block hover:text-brand-primary">
        +1 862 222 6880
      </a>
    </div>
  </aside>
</div>

<script>
  const drawer = document.querySelector<HTMLElement>('[data-mobile-drawer]');
  const panel = drawer?.querySelector<HTMLElement>('[data-drawer-panel]');
  const overlay = drawer?.querySelector<HTMLElement>('[data-drawer-overlay]');
  const closeBtn = drawer?.querySelector<HTMLButtonElement>('[data-drawer-close]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-mobile-toggle]');

  const setOpen = (open: boolean) => {
    if (!drawer || !panel) return;
    if (open) {
      drawer.hidden = false;
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        panel.classList.remove('translate-x-full');
      });
      const firstFocusable = panel.querySelector<HTMLElement>('button, a');
      firstFocusable?.focus();
    } else {
      drawer.setAttribute('aria-hidden', 'true');
      panel.classList.add('translate-x-full');
      document.body.style.overflow = '';
      setTimeout(() => {
        if (drawer) drawer.hidden = true;
      }, 200);
    }
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  closeBtn?.addEventListener('click', () => setOpen(false));
  overlay?.addEventListener('click', () => setOpen(false));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.hidden) setOpen(false);
  });

  // Close drawer when navigating
  drawer?.querySelectorAll('[data-drawer-link]').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  // Accordion behavior
  drawer?.querySelectorAll<HTMLButtonElement>('[data-drawer-accordion]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const group = btn.closest('[data-drawer-group]');
      const submenu = group?.querySelector<HTMLElement>('[data-drawer-submenu]');
      const chevron = btn.querySelector<HTMLElement>('[data-drawer-chevron]');
      if (submenu) submenu.hidden = expanded;
      if (chevron) chevron.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  });

  // Focus trap
  drawer?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || !panel || drawer.hidden) return;
    const focusables = panel.querySelectorAll<HTMLElement>(
      'a, button, input, [tabindex]:not([tabindex="-1"])'
    );
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
