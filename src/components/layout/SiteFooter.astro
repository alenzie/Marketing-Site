---
const platformLinks = [
  { href: '/solutions/ocula360', label: 'Ocula360' },
  { href: '/solutions/nsight360', label: 'Nsight360' },
  { href: '/solutions/2nd-opinion', label: '2nd Opinion' },
  { href: '/solutions/ophthal360', label: 'Ophthal360' },
];

const clinicianLinks = [
  { href: '/who-we-help', label: 'Who We Help' },
  { href: '/solutions', label: 'All Solutions' },
  { href: '/resources/journal-articles', label: 'Journal Articles' },
];

const scienceLinks = [
  { href: '/resources/journal-articles', label: 'Publications' },
  { href: '/resources/innovation-pipeline', label: 'Innovation Pipeline' },
  { href: '/resources/newsroom', label: 'Newsroom' },
  { href: '/resources', label: 'All Resources' },
];

const companyLinks = [
  { href: '/about', label: 'About' },
  { href: '/about#leadership', label: 'Leadership' },
  { href: '/resources/newsroom', label: 'Press' },
];
---

<footer class="relative bg-brand-navy text-white overflow-hidden mt-24">
  <!-- Aperture motif: concentric rings top-right -->
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -right-[180px] -top-[180px] w-[560px] h-[560px] rounded-full border border-brand-cyan/15"
  ></span>
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -right-[100px] -top-[100px] w-[400px] h-[400px] rounded-full border border-brand-cyan/10"
  ></span>
  <svg
    aria-hidden="true"
    class="pointer-events-none absolute -right-10 -top-10 w-[240px] h-[240px]"
    viewBox="0 0 240 240"
    fill="none"
  >
    <circle cx="120" cy="120" r="110" stroke="#27AAE1" stroke-opacity=".25" stroke-width="1"/>
    <circle cx="120" cy="120" r="80" stroke="#27AAE1" stroke-opacity=".2" stroke-width="1"/>
    <circle cx="120" cy="120" r="50" stroke="#27AAE1" stroke-opacity=".35" stroke-width="1"/>
    <circle cx="120" cy="120" r="22" stroke="#27AAE1" stroke-opacity=".6" stroke-width="1"/>
    <circle cx="120" cy="120" r="6" fill="#27AAE1"/>
    <g stroke="#27AAE1" stroke-opacity=".5" stroke-width="1" stroke-linecap="round">
      <line x1="120" y1="0" x2="120" y2="16"/>
      <line x1="120" y1="224" x2="120" y2="240"/>
      <line x1="0" y1="120" x2="16" y2="120"/>
      <line x1="224" y1="120" x2="240" y2="120"/>
    </g>
  </svg>

  <!-- CTA band -->
  <div class="relative border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-14 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 md:gap-10 items-center">
      <h2 class="text-3xl md:text-[38px] font-bold leading-[1.1] tracking-[-0.02em] max-w-[640px] m-0">
        See Ocula360 read a retina in <em class="not-italic text-brand-cyan">under two seconds</em>.
      </h2>
      <button
        type="button"
        data-open-modal="demo"
        class="inline-flex items-center gap-2 bg-white text-brand-primary font-semibold text-sm px-[22px] py-[14px] rounded-[10px] hover:bg-brand-cyan-soft transition-colors whitespace-nowrap"
      >
        Book a demo
        <svg class="w-[14px] h-[14px]" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Body: brand + 4 columns -->
  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr_1fr] gap-10">
    <div class="brand">
      <div class="flex items-center gap-3 mb-4">
        <img
          src="/ophthalytics-logo-white.svg"
          alt="Ophthalytics"
          width="300"
          height="36"
          class="h-9 w-auto block"
        />
      </div>
      <p class="text-[13px] text-slate-300 leading-[1.6] max-w-[280px] mb-5">
        Retinal AI platform for multi-disease detection, DRSS scoring, and explainable outputs.
      </p>

      <!-- Newsletter signup -->
      <form data-newsletter-form class="space-y-2 max-w-[280px]" novalidate>
        <p class="font-mono text-[10px] uppercase tracking-[.16em] text-brand-cyan mb-2">
          Stay in the loop
        </p>
        <div class="flex gap-2">
          <input
            type="email"
            name="email"
            required
            placeholder="your@email.com"
            aria-label="Email"
            class="flex-1 min-w-0 px-3 py-2 rounded-md bg-white/5 border border-white/15 text-white placeholder-slate-400 text-sm focus:border-brand-cyan focus:ring-2 focus:ring-brand-cyan/30 outline-none transition"
          />
          <button
            type="submit"
            class="bg-brand-cyan text-white font-semibold text-sm px-3 py-2 rounded-md hover:bg-brand-cyan-ink transition-colors"
          >
            Join
          </button>
        </div>
        <input type="hidden" name="firstName" value="" />
        <input type="hidden" name="lastName" value="" />
        <p data-newsletter-success hidden class="text-xs text-brand-cyan mt-1">
          Thanks — you're on the list.
        </p>
      </form>

      <div class="flex items-center gap-3 mt-5">
        <a
          href="https://www.linkedin.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-9 h-9 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 flex items-center justify-center transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.339 18.337v-8.59H5.667v8.59h2.672zM7.003 8.574a1.548 1.548 0 1 0 0-3.096 1.548 1.548 0 0 0 0 3.096zm11.335 9.763V13.63c0-2.474-1.338-3.625-3.123-3.625-1.44 0-2.084.791-2.444 1.347v-1.155h-2.711c.036.765 0 8.14 0 8.14h2.71v-4.798c0-.243.018-.485.09-.659.196-.486.64-.99 1.387-.99.977 0 1.369.746 1.369 1.838v4.61h2.722z"/>
          </svg>
        </a>
        <a
          href="mailto:info@ophthalytics.com"
          aria-label="Email Ophthalytics"
          class="w-9 h-9 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 flex items-center justify-center transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </a>
      </div>
    </div>

    <div class="col">
      <h5 class="font-mono text-[10px] text-brand-cyan uppercase tracking-[.16em] mb-4 mt-0">Platform</h5>
      <ul class="list-none p-0 m-0 space-y-2.5">
        {platformLinks.map((link) => (
          <li class="text-[13.5px] leading-[1.3]">
            <a href={link.href} class="text-slate-300 hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="col">
      <h5 class="font-mono text-[10px] text-brand-cyan uppercase tracking-[.16em] mb-4 mt-0">Clinicians</h5>
      <ul class="list-none p-0 m-0 space-y-2.5">
        {clinicianLinks.map((link) => (
          <li class="text-[13.5px] leading-[1.3]">
            <a href={link.href} class="text-slate-300 hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="col">
      <h5 class="font-mono text-[10px] text-brand-cyan uppercase tracking-[.16em] mb-4 mt-0">Science</h5>
      <ul class="list-none p-0 m-0 space-y-2.5">
        {scienceLinks.map((link) => (
          <li class="text-[13.5px] leading-[1.3]">
            <a href={link.href} class="text-slate-300 hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="col">
      <h5 class="font-mono text-[10px] text-brand-cyan uppercase tracking-[.16em] mb-4 mt-0">Company</h5>
      <ul class="list-none p-0 m-0 space-y-2.5">
        {companyLinks.map((link) => (
          <li class="text-[13.5px] leading-[1.3]">
            <a href={link.href} class="text-slate-300 hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
        <li class="text-[13.5px] leading-[1.3]">
          <button
            type="button"
            data-open-modal="contact"
            class="text-slate-300 hover:text-white transition-colors text-left"
          >
            Contact
          </button>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom bar: copyright + legal -->
  <div class="relative border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-5 flex flex-col md:flex-row justify-between items-center gap-3 font-mono text-[10px] text-slate-400 tracking-[.14em] uppercase">
      <div>© 2019 – 2026 Ophthalytics, Inc. · All rights reserved</div>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms</a>
        <a href="/accessibility" class="hover:text-white transition-colors">Accessibility</a>
      </div>
    </div>
  </div>
</footer>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-newsletter-form]');
  const success = document.querySelector<HTMLElement>('[data-newsletter-success]');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;
    const data = Object.fromEntries(new FormData(form).entries());
    // TODO: Wire to Resend endpoint — see 06b-forms-future.txt
    console.log('[NEWSLETTER_STUB]', data);
    form.reset();
    if (success) success.hidden = false;
  });
</script>
