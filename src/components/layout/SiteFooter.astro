---
const quickLinks = [
  { href: '/', label: 'Ophthalytics' },
  { href: '/who-we-help', label: 'Who We Help' },
  { href: '/resources', label: 'Resources' },
  { href: '/about', label: 'About' },
] as const;
---

<footer class="bg-brand-primary text-white mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

    <div>
      <div class="inline-flex items-center bg-white rounded-md px-3 py-2">
        <img src="/logo.png" alt="Ophthalytics" width="460" height="84" class="h-8 w-auto" />
      </div>
      <p class="text-sm text-white/70 mt-4">Wellness Through the Eyes™</p>
      <div class="flex items-center gap-3 mt-5">
        <a
          href="https://www.linkedin.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.339 18.337v-8.59H5.667v8.59h2.672zM7.003 8.574a1.548 1.548 0 1 0 0-3.096 1.548 1.548 0 0 0 0 3.096zm11.335 9.763V13.63c0-2.474-1.338-3.625-3.123-3.625-1.44 0-2.084.791-2.444 1.347v-1.155h-2.711c.036.765 0 8.14 0 8.14h2.71v-4.798c0-.243.018-.485.09-.659.196-.486.64-.99 1.387-.99.977 0 1.369.746 1.369 1.838v4.61h2.722z"/>
          </svg>
        </a>
        <a
          href="mailto:info@ophthalytics.com"
          aria-label="Email Ophthalytics"
          class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </a>
      </div>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-white/90">Quick Links</p>
      <ul class="mt-4 space-y-2 text-sm">
        {quickLinks.map((link) => (
          <li>
            <a href={link.href} class="text-white/70 hover:text-white transition-colors">
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <button
            type="button"
            data-open-modal="contact"
            class="text-white/70 hover:text-white transition-colors text-left"
          >
            Contact
          </button>
        </li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-white/90">Contact</p>
      <ul class="mt-4 space-y-2 text-sm text-white/70">
        <li>
          <a href="mailto:info@ophthalytics.com" class="hover:text-white transition-colors">
            info@ophthalytics.com
          </a>
        </li>
        <li>
          <a href="tel:+18622226880" class="hover:text-white transition-colors">
            +1 862 222 6880
          </a>
        </li>
        <li>Atlanta, Georgia, USA</li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wider text-white/90">Get the Latest News</p>
      <p class="mt-3 text-sm text-white/70">
        Stay informed by signing up with the latest news and insights from Ophthalytics.
      </p>
      <form data-newsletter-form class="mt-4 space-y-3" novalidate>
        <div class="grid grid-cols-2 gap-2">
          <input
            type="text"
            name="firstName"
            required
            placeholder="First Name"
            aria-label="First Name"
            class="w-full px-3 py-2 rounded-md bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm focus:border-white focus:ring-2 focus:ring-white/30 outline-none transition"
          />
          <input
            type="text"
            name="lastName"
            required
            placeholder="Last Name"
            aria-label="Last Name"
            class="w-full px-3 py-2 rounded-md bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm focus:border-white focus:ring-2 focus:ring-white/30 outline-none transition"
          />
        </div>
        <input
          type="email"
          name="email"
          required
          placeholder="Email"
          aria-label="Email"
          class="w-full px-3 py-2 rounded-md bg-white/10 border border-white/20 text-white placeholder-white/50 text-sm focus:border-white focus:ring-2 focus:ring-white/30 outline-none transition"
        />
        <button
          type="submit"
          class="w-full bg-white text-brand-primary font-semibold text-sm px-4 py-2.5 rounded-md hover:bg-brand-surface transition"
        >
          Sign Up
        </button>
        <p data-newsletter-success hidden class="text-sm text-white mt-2">
          Thanks! You're on the list.
        </p>
      </form>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-6 text-xs text-white/60 text-center md:text-left">
      Copyright © 2019 – 2026 | Ophthalytics Inc. |
      <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a> |
      <a href="/terms" class="hover:text-white transition-colors">Terms &amp; Conditions</a> |
      All Rights Reserved
    </div>
  </div>
</footer>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-newsletter-form]');
  const success = document.querySelector<HTMLElement>('[data-newsletter-success]');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form.reportValidity()) return;
    const data = Object.fromEntries(new FormData(form).entries());
    // TODO: Wire to Resend endpoint — see 06b-forms-future.txt
    console.log('[NEWSLETTER_STUB]', data);
    form.reset();
    if (success) success.hidden = false;
  });
</script>
