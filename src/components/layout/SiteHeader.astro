---
import DropdownMenu from './DropdownMenu.astro';
import MobileDrawer from './MobileDrawer.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const solutions = {
  label: 'Solutions',
  href: '/solutions',
  eyebrow: 'Our Solutions',
  items: [
    {
      name: 'Ocula360',
      href: '/solutions/ocula360',
      tagline: 'Foundational retinal AI platform',
      badge: 'FLAGSHIP',
    },
    {
      name: 'Nsight360',
      href: '/solutions/nsight360',
      tagline: 'AI-assisted screening for primary care',
    },
    {
      name: '2nd Opinion',
      href: '/solutions/2nd-opinion',
      tagline: 'Diagnostic support for optometry',
    },
    {
      name: 'Ophthal360',
      href: '/solutions/ophthal360',
      tagline: 'Autonomous AI for scale',
    },
  ],
  footerLink: { label: 'View all solutions', href: '/solutions' },
};

const resources = {
  label: 'Resources',
  href: '/resources',
  eyebrow: 'Resources',
  items: [
    {
      name: 'Journal Articles',
      href: '/resources/journal-articles',
      tagline: 'Peer-reviewed research',
    },
    {
      name: 'Newsroom',
      href: '/resources/newsroom',
      tagline: 'Press releases and company news',
    },
    {
      name: 'Innovation Pipeline',
      href: '/resources/innovation-pipeline',
      tagline: "What we're building next",
    },
  ],
  footerLink: { label: 'View all resources', href: '/resources' },
};

const company = {
  label: 'Company',
  href: '/about',
  eyebrow: 'Company',
  items: [
    {
      name: 'About',
      href: '/about',
      tagline: 'Our mission and story',
    },
  ],
  footerLink: { label: 'Contact us', href: '/about#contact' },
};

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');

const isSolutionsActive = isActive(solutions.href) || solutions.items.some((i) => isActive(i.href));
const isResourcesActive = isActive(resources.href) || resources.items.some((i) => isActive(i.href));
const isCompanyActive = isActive(company.href) || company.items.some((i) => isActive(i.href));
// "Science" links to innovation pipeline (closest existing route)
const scienceHref = '/resources/innovation-pipeline';
const isScienceActive = isActive(scienceHref);
const isWhoWeHelpActive = isActive('/who-we-help');

const mobileNav = [
  { type: 'group' as const, href: solutions.href, label: 'Solutions', items: solutions.items },
  { type: 'link' as const, href: '/who-we-help', label: 'Who We Help' },
  { type: 'link' as const, href: scienceHref, label: 'Science' },
  { type: 'group' as const, href: resources.href, label: 'Resources', items: resources.items },
  { type: 'group' as const, href: company.href, label: 'Company', items: company.items },
];
---

<header
  data-site-header
  class="sticky top-0 z-40 bg-white/80 backdrop-blur-[12px] backdrop-saturate-[140%] border-b border-brand-line transition-[background-color,border-color,box-shadow] duration-200"
>
  <nav
    class="max-w-7xl mx-auto px-6 lg:px-8 py-3.5 flex items-center justify-between gap-8"
    aria-label="Primary"
  >
    <a href="/" class="flex items-center shrink-0" aria-label="Ophthalytics home">
      <img
        src="/logo/ophthalytics-logo.svg"
        alt="Ophthalytics"
        width="300"
        height="34"
        class="h-[34px] w-auto block"
      />
    </a>

    <ul class="hidden md:flex items-center gap-6 lg:gap-7">
      <li>
        <DropdownMenu
          label={solutions.label}
          href={solutions.href}
          isActive={isSolutionsActive}
          items={solutions.items}
          footerLink={solutions.footerLink}
          eyebrow={solutions.eyebrow}
        />
      </li>
      <li>
        <a
          href="/who-we-help"
          class:list={[
            'relative text-[13.5px] font-medium tracking-[-0.005em] transition-colors py-2',
            isWhoWeHelpActive
              ? 'text-brand-primary after:absolute after:left-0 after:right-3 after:bottom-0 after:h-[2px] after:bg-brand-primary after:rounded-sm'
              : 'text-brand-body hover:text-brand-navy',
          ]}
          aria-current={isWhoWeHelpActive ? 'page' : undefined}
        >
          Who We Help
        </a>
      </li>
      <li>
        <a
          href={scienceHref}
          class:list={[
            'relative text-[13.5px] font-medium tracking-[-0.005em] transition-colors py-2',
            isScienceActive
              ? 'text-brand-primary after:absolute after:left-0 after:right-3 after:bottom-0 after:h-[2px] after:bg-brand-primary after:rounded-sm'
              : 'text-brand-body hover:text-brand-navy',
          ]}
          aria-current={isScienceActive ? 'page' : undefined}
        >
          Science
        </a>
      </li>
      <li>
        <DropdownMenu
          label={resources.label}
          href={resources.href}
          isActive={isResourcesActive}
          items={resources.items}
          footerLink={resources.footerLink}
          eyebrow={resources.eyebrow}
        />
      </li>
      <li>
        <DropdownMenu
          label={company.label}
          href={company.href}
          isActive={isCompanyActive}
          items={company.items}
          footerLink={company.footerLink}
          eyebrow={company.eyebrow}
        />
      </li>
    </ul>

    <div class="hidden md:flex items-center">
      <button
        type="button"
        data-open-modal="demo"
        class="inline-flex items-center gap-2 rounded-full bg-brand-cyan text-white font-semibold text-[13.5px] tracking-[-0.005em] px-[18px] py-[10px] transition-colors hover:bg-brand-cyan-ink shadow-[0_1px_0_rgba(255,255,255,0.5)_inset,0_6px_16px_-8px_rgba(39,170,225,0.55)] group"
      >
        Book a demo
        <span class="transition-transform duration-200 group-hover:translate-x-0.5" aria-hidden="true">→</span>
      </button>
    </div>

    <button
      type="button"
      data-mobile-toggle
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-md text-brand-ink hover:bg-brand-surface"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="6" x2="20" y2="6"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
  </nav>
</header>

<MobileDrawer nav={mobileNav} currentPath={currentPath} />

<script>
  // Solid white background after 40px scroll, translucent before
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  if (header) {
    const update = () => {
      if (window.scrollY > 40) {
        header.classList.remove('bg-white/80');
        header.classList.add('bg-white', 'shadow-[0_1px_0_rgba(15,35,80,0.04)]');
      } else {
        header.classList.add('bg-white/80');
        header.classList.remove('bg-white', 'shadow-[0_1px_0_rgba(15,35,80,0.04)]');
      }
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
