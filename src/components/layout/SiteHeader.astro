---
import AnnouncementBar from './AnnouncementBar.astro';
import DropdownMenu from './DropdownMenu.astro';
import MobileDrawer from './MobileDrawer.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const solutions = {
  label: 'Solutions',
  href: '/solutions',
  eyebrow: 'Our Solutions',
  items: [
    {
      name: 'Ocula360',
      href: '/solutions/ocula360',
      tagline: 'Foundational retinal AI platform',
      badge: 'FLAGSHIP',
    },
    {
      name: 'Nsight360',
      href: '/solutions/nsight360',
      tagline: 'AI-assisted screening for primary care',
    },
    {
      name: '2nd Opinion',
      href: '/solutions/2nd-opinion',
      tagline: 'Diagnostic support for optometry',
    },
    {
      name: 'Ophthal360',
      href: '/solutions/ophthal360',
      tagline: 'Autonomous AI for scale',
    },
  ],
  footerLink: { label: 'View all solutions', href: '/solutions' },
};

const resources = {
  label: 'Resources',
  href: '/resources',
  eyebrow: 'Resources',
  items: [
    {
      name: 'Articles',
      href: '/resources/articles',
      tagline: 'Industry insights from the Ophthalytics team',
      icon: '/images/resources/mini/articles.webp',
    },
    {
      name: 'Journal Articles',
      href: '/resources/journal-articles',
      tagline: 'Peer-reviewed research',
      icon: '/images/resources/mini/journal.webp',
    },
    {
      name: 'Newsroom',
      href: '/resources/newsroom',
      tagline: 'Press releases and company news',
      icon: '/images/resources/mini/newsroom.webp',
    },
    {
      name: 'Innovation Pipeline',
      href: '/resources/innovation-pipeline',
      tagline: "What we're building next",
      icon: '/images/resources/mini/innovation.webp',
    },
  ],
  footerLink: { label: 'View all resources', href: '/resources' },
};

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');

const isSolutionsActive = isActive(solutions.href) || solutions.items.some((i) => isActive(i.href));
const isResourcesActive = isActive(resources.href) || resources.items.some((i) => isActive(i.href));

const simpleLinks = [
  { href: '/', label: 'Home' },
  { href: '/who-we-help', label: 'Who We Help' },
  { href: '/about', label: 'About' },
];

const mobileNav = [
  { type: 'link' as const, href: '/', label: 'Home' },
  { type: 'group' as const, href: solutions.href, label: 'Solutions', items: solutions.items },
  { type: 'link' as const, href: '/who-we-help', label: 'Who We Help' },
  { type: 'group' as const, href: resources.href, label: 'Resources', items: resources.items },
  { type: 'link' as const, href: '/about', label: 'About' },
];
---

<AnnouncementBar
  message="<b>Peer-reviewed research</b> — Ophthalytics DR detection, validated on real-world fundus images"
  linkText="Read the study"
  linkHref="https://www.mdpi.com/2075-4418/13/3/393"
  linkExternal
  storageKey="ophlx-announcement-mdpi-dr"
/>

<header class="sticky top-0 z-40 bg-white/80 backdrop-blur border-b border-brand-line">
  <nav class="max-w-7xl mx-auto px-8 lg:px-12 py-4 flex items-center justify-between" aria-label="Primary">
    <a href="/" class="relative flex items-center" aria-label="Ophthalytics home">
      <div
        aria-hidden="true"
        class="absolute inset-0 -z-10 pointer-events-none scale-[1.8] [background:radial-gradient(ellipse_at_center,rgba(255,255,255,0.7)_0%,rgba(255,255,255,0)_65%)]"
      ></div>
      <img
        src="/ophthalytics-logo.svg"
        alt="Ophthalytics"
        width="300"
        height="34"
        class="relative h-9 w-auto"
      />
    </a>

    <ul class="hidden md:flex items-center gap-7">
      <li>
        <a
          href="/"
          class:list={[
            'text-base font-medium tracking-wide transition-colors',
            isActive('/')
              ? 'text-brand-primary'
              : 'text-brand-body hover:text-brand-primary',
          ]}
          aria-current={isActive('/') ? 'page' : undefined}
        >
          Home
        </a>
      </li>
      <li>
        <DropdownMenu
          label={solutions.label}
          href={solutions.href}
          isActive={isSolutionsActive}
          items={solutions.items}
          footerLink={solutions.footerLink}
          eyebrow={solutions.eyebrow}
        />
      </li>
      <li>
        <a
          href="/who-we-help"
          class:list={[
            'text-base font-medium tracking-wide transition-colors',
            isActive('/who-we-help')
              ? 'text-brand-primary'
              : 'text-brand-body hover:text-brand-primary',
          ]}
          aria-current={isActive('/who-we-help') ? 'page' : undefined}
        >
          Who We Help
        </a>
      </li>
      <li>
        <DropdownMenu
          label={resources.label}
          href={resources.href}
          isActive={isResourcesActive}
          items={resources.items}
          footerLink={resources.footerLink}
          eyebrow={resources.eyebrow}
        />
      </li>
      <li>
        <a
          href="/about"
          class:list={[
            'text-base font-medium tracking-wide transition-colors',
            isActive('/about')
              ? 'text-brand-primary'
              : 'text-brand-body hover:text-brand-primary',
          ]}
          aria-current={isActive('/about') ? 'page' : undefined}
        >
          About
        </a>
      </li>
      <li>
        <button
          type="button"
          data-open-modal="contact"
          class="text-base font-semibold tracking-wide text-brand-primary border-2 border-brand-primary rounded-md px-4 py-2 hover:bg-brand-primary hover:text-white transition"
        >
          Contact
        </button>
      </li>
    </ul>

    <button
      type="button"
      data-mobile-toggle
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-md text-brand-ink hover:bg-brand-surface"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" y1="6" x2="20" y2="6"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="18" x2="20" y2="18"></line>
      </svg>
    </button>
  </nav>
</header>

<MobileDrawer nav={mobileNav} currentPath={currentPath} />
