---
import '../../styles/global.css';
import SiteHeader from './SiteHeader.astro';
import SiteFooter from './SiteFooter.astro';
import DemoModal from '../interactive/DemoModal.astro';
import ContactModal from '../interactive/ContactModal.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  currentPath?: string;
}

const {
  title = 'Ophthalytics — Wellness Through the Eyes™',
  description = 'AI-Powered Retinal Intelligence for earlier detection and better health.',
  ogImage,
  currentPath,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <SiteHeader currentPath={currentPath} />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter />
    <DemoModal />
    <ContactModal />
  </body>
</html>
