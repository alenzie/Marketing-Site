---
interface Props {
  staticFallbackSrc: string;
  staticFallbackAlt: string;
  aspectClass?: string;
  maxWidthClass?: string;
  ariaLabel: string;
}

const {
  staticFallbackSrc,
  staticFallbackAlt,
  aspectClass = 'aspect-square',
  maxWidthClass = 'max-w-xl',
  ariaLabel,
} = Astro.props;
---

<div
  class={`relative ${aspectClass} ${maxWidthClass} rounded-2xl overflow-hidden mx-auto`}
  role="img"
  aria-label={ariaLabel}
>
  <div class="canvas-hero-stage hidden md:block absolute inset-0">
    <slot />
  </div>
  <img
    src={staticFallbackSrc}
    alt={staticFallbackAlt}
    class="block md:hidden absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />
</div>
